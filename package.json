{
  "name": "smelt",
  "version": "1.0.0",
  "description": "Smelt local GLB/IFC authoring tool",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "bun server.js",
    "dev": "bun server.js",
    "qwen:setup": "bun scripts/setup-qwen.js",
    "qwen:setup:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-qwen-windows.ps1",
    "qwen:setup:linux": "bash scripts/setup-qwen-linux.sh",
    "qwen:setup:cuda": "bun scripts/setup-qwen.js --cuda",
    "qwen:setup:vulkan": "bun scripts/setup-qwen.js --vulkan",
    "qwen:status": "bun scripts/qwen-status.js",
    "qwen:doctor": "bun scripts/qwen-doctor.js",
    "qwen:find:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-qwen-windows.ps1 -FindOnly -SkipBuild",
    "qwen:setup:windows:find": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-qwen-windows.ps1 -FindOnly -SkipBuild",
    "qwen:prereqs:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-qwen-windows.ps1 -PrereqsOnly"
  },
  "dependencies": {
    "@gltf-transform/core": "^4.1.1",
    "@gltf-transform/extensions": "^4.1.1",
    "express": "^4.21.1",
    "multer": "^1.4.5-lts.1",
    "draco3dgltf": "^1.5.7",
    "@thatopen/components": "^3.4.0",
    "@thatopen/fragments": "^3.4.1",
    "three": "^0.178.0",
    "vite": "^7.0.0",
    "web-ifc": "^0.0.77"
  }
}
