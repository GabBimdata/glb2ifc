  toolPartitionButton?.classList.toggle("active", state.authoring.tool === "partition");
  toolSlabButton?.classList.toggle("active", state.authoring.tool === "slab");
  toolDoorButton?.classList.toggle("active", state.authoring.tool === "door");
  toolWindowButton?.classList.toggle("active", state.authoring.tool === "window");
  toolRoofButton?.classList.toggle("active", state.authoring.tool === "roof");
  toolStairButton?.classList.toggle("active", state.authoring.tool === "stair");
  if (wallAlignmentSelect && wallAlignmentSelect.value !== state.authoring.wallAlignment) wallAlignmentSelect.value = state.authoring.wallAlignment;
  if (wallsFromSlabButton) wallsFromSlabButton.disabled = !(state.selected?.userData?.authoringType === "slab") || state.edit.active;
  if (roofFromSlabButton) roofFromSlabButton.disabled = !(state.selected?.userData?.authoringType === "slab") || state.edit.active;
  if (authoringStopButton) authoringStopButton.disabled = !isDrawingAuthoringTool();
  snapToggleButton?.classList.toggle("active", state.authoring.snap);
  xrayToggleButton?.classList.toggle("active", state.xray.active);
  helpToggleButton?.classList.toggle("active", shortcutsPanel?.classList.contains("open"));
  if (gridStepSelect) {
    const option = [...gridStepSelect.options].find((item) => Math.abs(Number(item.value) - Number(state.authoring.gridStep)) < 1e-9);
    if (option && gridStepSelect.value !== option.value) gridStepSelect.value = option.value;
  }
  updateStoreySelect();
  if (previousStoreyButton) previousStoreyButton.disabled = !state.modelRoot || getActiveStoreyIndex() <= 0;
  if (nextStoreyButton) nextStoreyButton.disabled = !state.modelRoot || getActiveStoreyIndex() >= state.authoring.storeys.length - 1;
  if (duplicateStoreyButton) duplicateStoreyButton.disabled = !state.modelRoot || !state.meshes.some((mesh) => mesh.userData?.storeyId === state.authoring.activeStoreyId && ["wall", "slab", "door", "window", "roof", "stair"].includes(mesh.userData?.authoringType));
  calibratePlanButton?.classList.toggle("active", state.authoring.calibration.active);
}

function updateTransformSnapping() {
  if (!state.transform) return;
  const step = Math.max(0.0001, Number(state.authoring.gridStep) || 0.1);
  const snap = state.authoring.snap ? step : null;
  state.transform.setTranslationSnap?.(snap);
}

function setHelpPanelOpen(open) {
  shortcutsPanel?.classList.toggle("open", Boolean(open));
  shortcutsPanel?.setAttribute("aria-hidden", open ? "false" : "true");
  helpToggleButton?.classList.toggle("active", Boolean(open));
}

function setXrayEnabled(enabled) {
  const next = Boolean(enabled);
  if (state.xray.active === next) {
    updateToolbarState();
    return;
  }

  state.xray.active = next;
  if (next) {
    applyXrayToMeshes();
    setStatus("Xray activé · Alt+Z pour revenir à l’affichage normal.", "ok");
  } else {
    restoreXrayMaterials();
    setStatus("Xray désactivé.", "ok");
  }
  updateToolbarState();
  renderProperties();
}

function applyXrayToMeshes() {
  for (const mesh of state.meshes) applyXrayToMesh(mesh);
}

function applyXrayToMesh(mesh) {
  if (!mesh?.material) return;
  const materials = Array.isArray(mesh.material) ? mesh.material : [mesh.material];
  for (const material of materials) {
    if (!material) continue;
    if (!state.xray.originals.has(material)) {
      state.xray.originals.set(material, {
        transparent: Boolean(material.transparent),
        opacity: Number.isFinite(Number(material.opacity)) ? Number(material.opacity) : 1,
        depthWrite: material.depthWrite,
        side: material.side,
      });
    }
    material.transparent = true;
    material.opacity = Math.min(0.28, Number.isFinite(Number(material.opacity)) ? Number(material.opacity) : 1);
    material.depthWrite = false;
    material.side = THREE.DoubleSide;
    material.needsUpdate = true;
  }
}

function restoreXrayMaterials() {
  for (const [material, original] of state.xray.originals.entries()) {
    if (!material) continue;
    material.transparent = original.transparent;
    material.opacity = original.opacity;
    material.depthWrite = original.depthWrite;
    material.side = original.side;
    material.needsUpdate = true;
  }
  state.xray.originals.clear();
}

function deleteSelectedMesh() {
  const mesh = state.selected;
  if (!mesh || !mesh.parent || mesh.userData?.__modelerOverlay) return false;

  if (isOpeningMesh(mesh)) return deleteSelectedOpening(mesh);

  if (state.edit.active) setEditMode(false);
  const parent = mesh.parent;
  const index = parent.children.indexOf(mesh);
  const label = `Supprimer ${mesh.name || `Mesh_${mesh.userData.__modelerId}`}`;

  const linkedOpenings = mesh.userData?.authoringType === "wall"
    ? collectOpeningMeshesForWall(mesh)
    : [];

  selectMesh(null);
  for (const openingMesh of linkedOpenings) {
    if (openingMesh.mesh?.parent) openingMesh.mesh.parent.remove(openingMesh.mesh);
  }
  parent.remove(mesh);
  if (state.modelRoot) indexMeshes(state.modelRoot);
  pushHistory({
    type: "deleteMesh",
    label,
    mesh,
    parent,
    index,
    linkedOpenings,
  });
  renderTree();
  renderProperties();
  markDirty();
  updateUiEnabled();
  setStatus(`${escapeHtml(label)} · Ctrl/Cmd+Z pour annuler.`, "ok");
  return true;
}

function isOpeningMesh(mesh) {
  return mesh && (mesh.userData?.authoringType === "door" || mesh.userData?.authoringType === "window");
}

function deleteSelectedOpening(mesh) {
  if (!mesh || !mesh.parent) return false;
  if (state.edit.active) setEditMode(false);

  const link = getOpeningLinkForMesh(mesh);
  if (!link?.wall || !link?.opening) {
    // Better to fail loudly than to remove the visible door/window while leaving
    // a permanent cut in the host wall. This usually means the asset lost its
    // wall/opening metadata during a round-trip.
    setStatus("Impossible de supprimer proprement cet ouvrant : mur hôte introuvable. Essaie de recharger le projet ou de sélectionner l’ouvrant depuis le tree.", "warning");
    return false;
  }

  const parent = mesh.parent;
  const index = parent.children.indexOf(mesh);
  const label = `Supprimer ${mesh.name || openingToolLabel(mesh.userData.authoringType)}`;
  const wallId = link.wall.userData.__modelerId;
  const opening = cloneOpening(link.opening);

  removeOpeningFromWall(link.wall, opening.id);
  selectMesh(null);
  parent.remove(mesh);
  if (state.modelRoot) indexMeshes(state.modelRoot);

  pushHistory({
    type: "deleteOpening",
    label,
    mesh,
    parent,
    index,
    wallId,
    opening,
  });

  renderTree();
  renderProperties();
  markDirty();
  updateUiEnabled();
  setStatus(`${escapeHtml(label)} · mur restauré · Ctrl/Cmd+Z pour annuler.`, "ok");
  return true;
}

function applyDeleteMeshHistory(action, direction) {
  const mesh = action.mesh;
  const parent = action.parent || state.modelRoot || ensureAuthoringRoot();
  if (!mesh || !parent) return;

  const linkedOpenings = Array.isArray(action.linkedOpenings) ? action.linkedOpenings : [];

  if (direction === "undo") {
    if (!mesh.parent) {
      parent.add(mesh);
      if (Number.isFinite(action.index) && action.index >= 0 && action.index < parent.children.length - 1) {
        const currentIndex = parent.children.indexOf(mesh);
        if (currentIndex >= 0) {
          parent.children.splice(currentIndex, 1);
          parent.children.splice(action.index, 0, mesh);
        }
      }
    }
    for (const item of linkedOpenings) {
      if (!item?.mesh) continue;
      const itemParent = item.parent || parent;
      if (!item.mesh.parent) {
        itemParent.add(item.mesh);
        if (Number.isFinite(item.index) && item.index >= 0 && item.index < itemParent.children.length - 1) {
          const currentIndex = itemParent.children.indexOf(item.mesh);
          if (currentIndex >= 0) {
            itemParent.children.splice(currentIndex, 1);
            itemParent.children.splice(item.index, 0, item.mesh);
          }
        }
      }
      if (state.xray.active) applyXrayToMesh(item.mesh);
    }
    if (state.xray.active) applyXrayToMesh(mesh);
  } else if (mesh.parent) {
    for (const item of linkedOpenings) {
      if (item?.mesh?.parent) item.mesh.parent.remove(item.mesh);
    }
    if (state.selected === mesh) selectMesh(null);
    mesh.parent.remove(mesh);
  }

  if (state.modelRoot) {
    indexMeshes(state.modelRoot);
    refreshAuthoredWallMiters();
  }
}

function applyDeleteOpeningHistory(action, direction) {
  const mesh = action.mesh;
  const parent = action.parent || state.modelRoot || ensureAuthoringRoot();
  const wall = meshByModelerId(action.wallId);
  const opening = cloneOpening(action.opening);
  if (!mesh || !parent || !wall || !opening) return;

  if (direction === "undo") {
    addOpeningToWall(wall, opening);
    if (!mesh.parent) {
      parent.add(mesh);
      if (Number.isFinite(action.index) && action.index >= 0 && action.index < parent.children.length - 1) {
        const currentIndex = parent.children.indexOf(mesh);
        if (currentIndex >= 0) {
          parent.children.splice(currentIndex, 1);
          parent.children.splice(action.index, 0, mesh);
        }
      }
    }
    updateOpeningMeshFromWallOpening(mesh, wall, opening);
    if (state.xray.active) applyXrayToMesh(mesh);
  } else {
    removeOpeningFromWall(wall, opening.id);
    if (state.selected === mesh) selectMesh(null);
    if (mesh.parent) mesh.parent.remove(mesh);
  }

  if (state.modelRoot) {
    indexMeshes(state.modelRoot);
    refreshWallMeshGeometry(wall);
  }
}

function applyDeleteStoreyHistory(action, direction) {
  if (!action?.storey) return;
  const storeyId = action.storey.id;
  const root = state.modelRoot || ensureAuthoringRoot();
  const records = Array.isArray(action.meshRecords) ? action.meshRecords : [];

  if (direction === "undo") {
    if (!state.authoring.storeys.some((storey) => storey.id === storeyId)) {
      const insertAt = THREE.MathUtils.clamp(Number(action.index) || 0, 0, state.authoring.storeys.length);
      state.authoring.storeys.splice(insertAt, 0, { ...action.storey });
    }
    restoreReferencePlanFromHistory(action.referenceRecord);
    for (const record of records) {
      addChildBackAt(record, root);
      if (state.xray.active && record.mesh) applyXrayToMesh(record.mesh);
    }
    state.authoring.activeStoreyId = storeyId;
  } else {
    if (state.selected?.userData?.storeyId === storeyId) selectMesh(null);
    for (const record of records) {
      if (record?.mesh?.parent) record.mesh.parent.remove(record.mesh);
    }
    if (action.referenceRecord?.ref?.mesh?.parent) action.referenceRecord.ref.mesh.parent.remove(action.referenceRecord.ref.mesh);
    state.authoring.references.delete(storeyId);
    state.authoring.storeys = (state.authoring.storeys || []).filter((storey) => storey.id !== storeyId);
    state.authoring.activeStoreyId = getFallbackStoreyIdAfterDeletion(Number(action.index) || 0, action.activeAfter);
  }

  updateAuthoringPlaneElevation();
  if (state.modelRoot) {
    indexMeshes(state.modelRoot);
    refreshAuthoredWallMiters();
  }
  updateReferenceVisibilityAndElevation();
}

function beginObjectTransformDrag() {
  if (!state.selected || state.edit.active) return;
  state.history.objectDragStart = {
    meshId: state.selected.userData.__modelerId,
    before: serializeObjectTransform(state.selected),
  };
}

function finishObjectTransformDrag() {
  const start = state.history.objectDragStart;
  state.history.objectDragStart = null;
  if (!start) return;

  const mesh = meshByModelerId(start.meshId);
  if (!mesh) return;
  if (state.transform?.getMode?.() === "translate" && state.authoring.snap) snapObjectPositionToGrid(mesh);
  const after = serializeObjectTransform(mesh);
  if (!objectTransformsEqual(start.before, after)) {
    pushHistory({
      type: "objectTransform",
      label: "Object transform",
      meshId: start.meshId,
      before: start.before,
      after,
    });
  }
}

function snapObjectPositionToGrid(object) {
  if (!object) return;
  const step = Math.max(0.0001, Number(state.authoring.gridStep) || 0.1);
  object.position.x = Math.round(object.position.x / step) * step;
  object.position.z = Math.round(object.position.z / step) * step;
  object.updateMatrixWorld(true);
}

function serializeObjectTransform(object) {
  return {
    position: object.position.toArray(),
    quaternion: object.quaternion.toArray(),
    scale: object.scale.toArray(),
  };
}

function applyObjectTransform(object, transform) {
  object.position.fromArray(transform.position || [0, 0, 0]);
  object.quaternion.fromArray(transform.quaternion || [0, 0, 0, 1]);
  object.scale.fromArray(transform.scale || [1, 1, 1]);
  object.updateMatrixWorld(true);
}

function objectTransformsEqual(a, b) {
  return arraysNearlyEqual(a?.position, b?.position) && arraysNearlyEqual(a?.quaternion, b?.quaternion) && arraysNearlyEqual(a?.scale, b?.scale);
}

function arraysNearlyEqual(a = [], b = [], eps = 1e-8) {
  if (a.length !== b.length) return false;
  return a.every((value, index) => Math.abs(Number(value) - Number(b[index])) <= eps);
}

function vertexEntriesFromStartMap(map) {
  return [...map.entries()].map(([id, vector]) => [id, vector.x, vector.y, vector.z]);
}

function vertexEntriesFromGeometry(mesh, ids) {
  const position = mesh.geometry.getAttribute("position");
  const out = [];
  for (const id of ids) {
    if (id < 0 || id >= position.count) continue;
    out.push([id, position.getX(id), position.getY(id), position.getZ(id)]);
  }
  return out;
}

function vertexEntriesChanged(before, after) {
  if (before.length !== after.length) return true;
  for (let i = 0; i < before.length; i++) {
    if (before[i][0] !== after[i][0]) return true;
    for (let j = 1; j < 4; j++) {
      if (Math.abs(before[i][j] - after[i][j]) > 1e-8) return true;
    }
  }
  return false;
}

function applyGeometryEntries(mesh, entries) {
  if (!canEditSubGeometry(mesh)) return;
  const position = mesh.geometry.getAttribute("position");
  for (const [id, x, y, z] of entries) {
    if (id < 0 || id >= position.count) continue;
    position.setXYZ(id, x, y, z);
  }
  position.needsUpdate = true;
  mesh.geometry.computeVertexNormals();
  mesh.geometry.computeBoundingBox();
  mesh.geometry.computeBoundingSphere();
  mesh.updateMatrixWorld(true);
}

function meshByModelerId(id) {
  if (id == null) return null;
  const wanted = String(id);
  return state.meshes.find((mesh) => String(mesh.userData.__modelerId) === wanted) || null;
}


function refreshAuthoredWallMiters() {
  const walls = state.meshes.filter((mesh) => mesh.userData?.authoringType === "wall" && mesh.userData?.wallPath);
  const eps = Math.max(0.005, (Number(state.authoring.gridStep) || 0.1) * 0.35);

  for (const wall of walls) {
    wall.userData.wallPath.prev = null;
    wall.userData.wallPath.next = null;
  }

  for (const wall of walls) {
    const data = wall.userData.wallPath;
    const storeyId = wall.userData.storeyId;
    const prev = findConnectedWallForEndpoint(walls, wall, data.start, "start", eps, storeyId);
    const next = findConnectedWallForEndpoint(walls, wall, data.end, "end", eps, storeyId);
    if (prev) data.prev = prev;
    if (next) data.next = next;
  }

  for (const wall of walls) refreshWallMeshGeometry(wall);
}

function findConnectedWallForEndpoint(walls, wall, endpoint, endpointKind, eps, storeyId) {
  let best = null;
  for (const other of walls) {
    if (other === wall || other.userData.storeyId !== storeyId) continue;
    const data = other.userData.wallPath;
    const candidates = [
      { at: data.start, opposite: data.end },
      { at: data.end, opposite: data.start },
    ];
    for (const candidate of candidates) {
      const distance = Math.hypot(endpoint.x - candidate.at.x, endpoint.z - candidate.at.z);
      if (distance <= eps && (!best || distance < best.distance)) {
        best = { distance, point: candidate.opposite.clone() };
      }
    }
  }
  return best?.point || null;
}

function pushHistory(action) {
  if (!action) return;
  state.history.undoStack.push(action);
  if (state.history.undoStack.length > state.history.max) state.history.undoStack.shift();
  state.history.redoStack.length = 0;
  updateUiEnabled();
}

function undoLastAction() {
  const action = state.history.undoStack.pop();
  if (!action) return;
  applyHistoryAction(action, "undo");
  state.history.redoStack.push(action);
  updateAfterHistory(action, "Annulé");
}

function redoLastAction() {
  const action = state.history.redoStack.pop();
  if (!action) return;
  applyHistoryAction(action, "redo");
  state.history.undoStack.push(action);
  updateAfterHistory(action, "Rétabli");
}

function applyHistoryAction(action, direction) {
  if (action.type === "createMesh") {
    applyCreateMeshHistory(action, direction);
    return;
  }

  if (action.type === "createMeshes") {
    applyCreateMeshesHistory(action, direction);
    return;
  }

  if (action.type === "deleteMesh") {
    applyDeleteMeshHistory(action, direction);
    return;
  }

  if (action.type === "deleteOpening") {
    applyDeleteOpeningHistory(action, direction);
    return;
  }

  if (action.type === "deleteStorey") {
    applyDeleteStoreyHistory(action, direction);
    return;
  }

  if (action.type === "createOpening") {
    applyCreateOpeningHistory(action, direction);
    return;
  }

  if (action.type === "editOpening") {
    applyEditOpeningHistory(action, direction);
    return;
  }

  if (action.type === "standaloneOpeningDimension") {
    applyStandaloneOpeningDimensionHistory(action, direction);
    return;
  }

  const mesh = meshByModelerId(action.meshId);
  if (!mesh) return;
  const payload = direction === "undo" ? action.before : action.after;

  if (action.type === "geometryPatch") applyGeometryEntries(mesh, payload);
  else if (action.type === "objectTransform") applyObjectTransform(mesh, payload);
  else if (action.type === "name") mesh.name = payload;
}

function applyCreateMeshHistory(action, direction) {
  const mesh = action.mesh;
  if (!mesh) return;
  const parent = action.parent || state.modelRoot || ensureAuthoringRoot();
  if (direction === "undo") {
    if (mesh.parent) mesh.parent.remove(mesh);
  } else if (!mesh.parent) {
    parent.add(mesh);
  }
  if (state.modelRoot) {
    indexMeshes(state.modelRoot);
    refreshAuthoredWallMiters();
  }
}

function applyCreateMeshesHistory(action, direction) {
  const meshes = Array.isArray(action.meshes) ? action.meshes : [];
  const parent = action.parent || state.modelRoot || ensureAuthoringRoot();
  for (const mesh of meshes) {
    if (!mesh) continue;
    if (direction === "undo") {
      if (mesh.parent) mesh.parent.remove(mesh);
    } else if (!mesh.parent) {
      parent.add(mesh);
    }
  }
  if (state.modelRoot) {
    indexMeshes(state.modelRoot);
    refreshAuthoredWallMiters();
  }
}

function applyCreateOpeningHistory(action, direction) {
  const mesh = action.mesh;
  const parent = action.parent || state.modelRoot || ensureAuthoringRoot();
  const wall = meshByModelerId(action.wallId);
  if (direction === "undo") {
    if (action.opening) removeOpeningFromWall(wall, action.opening.id);
    if (mesh?.parent) mesh.parent.remove(mesh);
  } else {
    if (action.opening) addOpeningToWall(wall, action.opening);
    if (mesh && !mesh.parent) parent.add(mesh);
  }
  if (state.modelRoot) indexMeshes(state.modelRoot);
}

function updateAfterHistory(action, prefix) {
  if (action.type === "deleteMesh" || action.type === "deleteOpening" || action.type === "deleteStorey") {
    if (state.modelRoot) {
      indexMeshes(state.modelRoot);
      refreshAuthoredWallMiters();
    }
    if (action.type === "deleteStorey") selectMesh(null);
    else selectMesh(action.mesh?.parent ? action.mesh : null);
    renderTree();
    renderProperties();
    markDirty();
    updateUiEnabled();
    setStatus(`${prefix} : ${escapeHtml(action.label || "suppression")}.`, "ok");
    return;
  }

  if (action.type === "createMesh" || action.type === "createMeshes" || action.type === "createOpening") {
    if (state.modelRoot) {
      indexMeshes(state.modelRoot);
      refreshAuthoredWallMiters();
    }
    const firstMesh = action.mesh || action.meshes?.[0];
    selectMesh(firstMesh?.parent ? firstMesh : null);
    renderTree();
    renderProperties();
    markDirty();
    updateUiEnabled();
    setStatus(`${prefix} : ${escapeHtml(action.label || "action")}.`, "ok");
    return;
  }

  const mesh = meshByModelerId(action.meshId);
  if (mesh) selectMesh(mesh);
  if (state.edit.active && mesh) rebuildEditOverlay();
  updateEditPivotToSelection();
  updateBoxHelper();
  renderTree();
  renderProperties();
  markDirty();
  updateUiEnabled();
  setStatus(`${prefix} : ${escapeHtml(action.label || "action")}.`, "ok");
}

function resetSelectedTransform() {
  if (!state.selected) return;
  const original = state.selected.userData.__originalTransform;
  if (!original) return;

  const before = serializeObjectTransform(state.selected);
  state.selected.position.copy(original.position);
  state.selected.quaternion.copy(original.quaternion);
  state.selected.scale.copy(original.scale);
  state.selected.updateMatrixWorld(true);
  const after = serializeObjectTransform(state.selected);

  if (!objectTransformsEqual(before, after)) {
    pushHistory({
      type: "objectTransform",
      label: "Reset transform",
      meshId: state.selected.userData.__modelerId,
      before,
      after,
    });
  }

  updateBoxHelper();
  renderProperties();
  markDirty();
}

function updateUiEnabled() {
  const hasModel = Boolean(state.modelRoot);
  const hasSelection = Boolean(state.selected);
  const canSubEdit = hasSelection && canEditSubGeometry(state.selected);
  const hasTransformTarget = state.edit.active ? hasEditComponentSelection() : hasSelection;

  fitButton.disabled = !hasModel;
  clearButton.disabled = !hasModel;
  exportGlbButton.disabled = !hasModel;
  convertIfcButton.disabled = !hasModel;

  if (newSceneButton) newSceneButton.disabled = false;
  if (toolSelectButton) toolSelectButton.disabled = false;
  if (toolWallButton) toolWallButton.disabled = state.edit.active;
  if (toolPartitionButton) toolPartitionButton.disabled = state.edit.active;
  if (toolSlabButton) toolSlabButton.disabled = state.edit.active;
  if (toolDoorButton) toolDoorButton.disabled = state.edit.active || !state.modelRoot;
  if (toolWindowButton) toolWindowButton.disabled = state.edit.active || !state.modelRoot;
  if (toolRoofButton) toolRoofButton.disabled = state.edit.active || !state.modelRoot;
  if (toolStairButton) toolStairButton.disabled = state.edit.active;
  if (wallAlignmentSelect) wallAlignmentSelect.disabled = state.edit.active;
  if (wallsFromSlabButton) wallsFromSlabButton.disabled = !(state.selected?.userData?.authoringType === "slab") || state.edit.active;
  if (roofFromSlabButton) roofFromSlabButton.disabled = !(state.selected?.userData?.authoringType === "slab") || state.edit.active;
  if (snapToggleButton) snapToggleButton.disabled = false;
  if (gridStepSelect) gridStepSelect.disabled = false;
  if (newStoreyButton) newStoreyButton.disabled = !hasModel;
  if (duplicateStoreyButton) duplicateStoreyButton.disabled = !hasModel || !state.meshes.some((mesh) => mesh.userData?.storeyId === state.authoring.activeStoreyId && ["wall", "slab", "door", "window", "roof", "stair"].includes(mesh.userData?.authoringType));
  if (deleteStoreyButton) deleteStoreyButton.disabled = !hasModel || (state.authoring.storeys || []).length <= 1;
  if (previousStoreyButton) previousStoreyButton.disabled = !hasModel || getActiveStoreyIndex() <= 0;
  if (nextStoreyButton) nextStoreyButton.disabled = !hasModel || getActiveStoreyIndex() >= state.authoring.storeys.length - 1;
  if (storeySelect) storeySelect.disabled = !hasModel;
  if (referencePlanButton) referencePlanButton.disabled = false;
  if (calibratePlanButton) calibratePlanButton.disabled = !getActiveReferencePlan();

  if (objectModeButton) objectModeButton.disabled = !hasModel;
  if (editModeButton) editModeButton.disabled = !canSubEdit;
  if (vertexModeButton) vertexModeButton.disabled = !state.edit.active;
  if (edgeModeButton) edgeModeButton.disabled = !state.edit.active;
