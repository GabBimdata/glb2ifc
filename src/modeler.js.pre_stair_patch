  if (boxSelectButton) boxSelectButton.disabled = !state.edit.active;
  if (undoButton) undoButton.disabled = state.history.undoStack.length === 0;
  if (redoButton) redoButton.disabled = state.history.redoStack.length === 0;
  if (xrayToggleButton) xrayToggleButton.disabled = !hasModel;

  translateButton.disabled = !hasTransformTarget;
  rotateButton.disabled = !hasTransformTarget;
  scaleButton.disabled = !hasTransformTarget;
  localButton.disabled = !hasTransformTarget;
  worldButton.disabled = !hasTransformTarget;
  resetTransformButton.disabled = !hasSelection || state.edit.active;

  updateToolbarState();
}

function markDirty() {
