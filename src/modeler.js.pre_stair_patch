    const file = event.target.files?.[0];
    if (file) loadReferencePlanFile(file).catch((error) => {
      console.error(error);
      setStatus(`Impossible d’importer le plan : ${escapeHtml(error.message || error)}`, "error");
    });
    event.target.value = "";
  });
  calibratePlanButton?.addEventListener("click", beginReferenceCalibration);

  fitButton.addEventListener("click", () => fitCameraToObject(state.modelRoot || state.grid));
  clearButton.addEventListener("click", clearScene);
  exportGlbButton.addEventListener("click", exportGlbDownload);
  convertIfcButton.addEventListener("click", convertEditedGlbToIfc);

  translateButton.addEventListener("click", () => setTransformMode("translate"));
  rotateButton.addEventListener("click", () => setTransformMode("rotate"));
  scaleButton.addEventListener("click", () => setTransformMode("scale"));
  localButton.addEventListener("click", () => setTransformSpace("local"));
  worldButton.addEventListener("click", () => setTransformSpace("world"));
  resetTransformButton.addEventListener("click", resetSelectedTransform);

  objectModeButton?.addEventListener("click", () => setEditMode(false));
  editModeButton?.addEventListener("click", () => setEditMode(!state.edit.active));
  vertexModeButton?.addEventListener("click", () => setComponentMode("vertex"));
  edgeModeButton?.addEventListener("click", () => setComponentMode("edge"));
  faceModeButton?.addEventListener("click", () => setComponentMode("face"));
  boxSelectButton?.addEventListener("click", () => armBoxSelect());
  undoButton?.addEventListener("click", undoLastAction);
  redoButton?.addEventListener("click", redoLastAction);
  xrayToggleButton?.addEventListener("click", () => setXrayEnabled(!state.xray.active));
  helpToggleButton?.addEventListener("click", () => setHelpPanelOpen(!shortcutsPanel?.classList.contains("open")));
  helpCloseButton?.addEventListener("click", () => setHelpPanelOpen(false));

  window.addEventListener("keydown", (event) => {
    if (event.target && ["INPUT", "TEXTAREA", "SELECT"].includes(event.target.tagName)) return;

    const key = event.key.toLowerCase();

    if (event.altKey && key === "z") {
      event.preventDefault();
      setXrayEnabled(!state.xray.active);
      return;
    }

    if (event.key === "Delete" || event.key === "Backspace") {
      if (deleteSelectedMesh()) {
        event.preventDefault();
        return;
      }
    }

    if (handleUndoRedoShortcut(event)) return;
    if (handleNumpadViewShortcut(event)) return;

    if (event.key === "Tab") {
      event.preventDefault();
      setEditMode(!state.edit.active);
      return;
    }

    if (event.key === "Escape") {
      if (state.authoring.calibration.active) cancelReferenceCalibration();
      else if (state.authoring.drawStart || isDrawingAuthoringTool()) stopAuthoringTool({ silent: false });
      else if (state.selectBox.armed || state.selectBox.dragging) cancelBoxSelect();
      else if (state.edit.active && hasEditComponentSelection()) clearEditComponentSelection();
      else if (state.edit.active) setEditMode(false);
      else selectMesh(null);
      return;
    }

    if (state.edit.active) {
      if (event.key === "1") setComponentMode("vertex");
      if (event.key === "2") setComponentMode("edge");
      if (event.key === "3") setComponentMode("face");
      if (key === "a") {
        event.preventDefault();
        selectAllEditComponents();
      }
      if (key === "b") {
        event.preventDefault();
        armBoxSelect();
      }
    }

    if (!state.edit.active) {
      if (key === "v") setAuthoringTool("select");
      if (key === "m") setAuthoringTool("wall");
      if (key === "i") setAuthoringTool("partition");
      if (key === "d") setAuthoringTool("slab");
      if (key === "o") setAuthoringTool("door");
      if (key === "f") setAuthoringTool("window");
      if (key === "h") setAuthoringTool("roof");
      if (key === "e") setAuthoringTool("stair");
      if (key === "p") setAuthoringSnap(!state.authoring.snap);
      if (key === "pageup") navigateStorey(1);
      if (key === "pagedown") navigateStorey(-1);
      if (key === "c") setWallAlignment("center");
      if (key === "[") cycleWallAlignment(-1);
      if (key === "]") cycleWallAlignment(1);
    }

    if (key === "g" || key === "t") setTransformMode("translate");
    if (key === "r") setTransformMode("rotate");
    if (key === "s") setTransformMode("scale");
    if (key === "l") setTransformSpace("local");
    if (key === "w") setTransformSpace("world");
  });
}

function resize() {
  const rect = container.getBoundingClientRect();
  const width = Math.max(1, rect.width);
  const height = Math.max(1, rect.height);
  const aspect = width / height;

  if (state.perspectiveCamera) {
    state.perspectiveCamera.aspect = aspect;
    state.perspectiveCamera.updateProjectionMatrix();
  }

  updateOrthographicCameraBounds(aspect);
  state.renderer.setSize(width, height, false);
}


function viewportAspect() {
  const rect = container.getBoundingClientRect();
  return Math.max(1, rect.width) / Math.max(1, rect.height);
}

function updateOrthographicCameraBounds(aspect = viewportAspect()) {
  if (!state.orthographicCamera) return;
  const halfHeight = Math.max(0.1, Number(state.view.orthoHalfHeight) || 10);
  state.orthographicCamera.left = -halfHeight * aspect;
  state.orthographicCamera.right = halfHeight * aspect;
  state.orthographicCamera.top = halfHeight;
  state.orthographicCamera.bottom = -halfHeight;
  state.orthographicCamera.updateProjectionMatrix();
}

function setActiveCamera(camera) {
  if (!camera || state.camera === camera) return;
  state.camera = camera;
  if (state.controls) {
    state.controls.object = camera;
    state.controls.update();
  }
  if (state.transform) {
    state.transform.camera = camera;
  }
  resize();
}

function switchToPerspectiveCamera(options = {}) {
  if (!state.perspectiveCamera || state.camera === state.perspectiveCamera) return;

  const current = state.camera;
  const target = state.controls?.target?.clone?.() || new THREE.Vector3();
  const { radius } = modelViewBounds();
  const currentOffset = current.position.clone().sub(target);
  const direction = currentOffset.lengthSq() > 1e-9
    ? currentOffset.normalize()
    : new THREE.Vector3(1, 0.72, 1).normalize();
  const distance = Math.max(radius * 2.4, options.distance || 4);

  state.perspectiveCamera.position.copy(target).add(direction.multiplyScalar(distance));
  state.perspectiveCamera.up.copy(current.up);
  state.perspectiveCamera.near = Math.max(0.001, distance / 1000);
  state.perspectiveCamera.far = Math.max(1000, distance * 100);
  state.perspectiveCamera.lookAt(target);
  state.perspectiveCamera.updateProjectionMatrix();
  setActiveCamera(state.perspectiveCamera);
  if (state.controls) {
    state.controls.target.copy(target);
    state.controls.update();
  }
  if (!options.silent) setStatus("Vue perspective.", "ok");
}

function isEditableTextTarget(target) {
  if (!(target instanceof Element)) return false;
  return Boolean(target.closest('input, textarea, select, option, [contenteditable="true"], .allow-text-selection'));
}

function bindPropertyControlEventGuards() {
  if (!properties) return;

  const stopForEditable = (event) => {
    if (!isEditableTextTarget(event.target)) return;
    event.stopPropagation();
  };

  for (const eventName of [
    "pointerdown", "pointerup", "mousedown", "mouseup", "click", "dblclick",
    "keydown", "keyup", "keypress", "selectstart", "dragstart",
  ]) {
    properties.addEventListener(eventName, stopForEditable, { capture: true });
  }
}

function clearBrowserSelection() {
  const selection = window.getSelection?.();
  if (selection && selection.rangeCount) selection.removeAllRanges();
}

function preventAccidentalTextSelection(event) {
  if (isEditableTextTarget(event.target)) return;
  event.preventDefault();
}

function preventMultiClickTextSelection(event) {
  if (isEditableTextTarget(event.target)) return;
  if (event.detail > 1) {
    event.preventDefault();
    clearBrowserSelection();
  }
}

function beginViewportPointerInteraction() {
  document.body.classList.add("modeler-no-select");
  clearBrowserSelection();
}

function endViewportPointerInteraction(event = null) {
  document.body.classList.remove("modeler-no-select");
  if (event?.target && isEditableTextTarget(event.target)) return;
  clearBrowserSelection();
}

function maybeSwitchFromOrthoToPerspectiveOnDrag(event) {
  const down = state.pointerDown;
  if (!down?.orthoCamera || !state.camera?.isOrthographicCamera || state.isTransformDragging) return;
  if (!(event.buttons & 1)) return;
  if (state.selectBox.dragging || state.selectBox.armed) return;
  if (isDrawingAuthoringTool()) return;

  // Keep numpad orthographic views when the gesture is a pan.
  // OrbitControls commonly maps Shift/Ctrl/Cmd + left drag to pan; only a plain
  // left-drag orbit should leave ortho and return to perspective.
  if (down.panModifier || event.shiftKey || event.ctrlKey || event.metaKey || event.altKey) return;

  const moved = Math.hypot(event.clientX - down.x, event.clientY - down.y);
  if (moved < 7) return;

  down.orthoCamera = false;
  switchToPerspectiveCamera({ silent: true });
}

function animate() {
  requestAnimationFrame(animate);
  state.controls.update();
  state.renderer.render(state.scene, state.camera);
}

function handleUndoRedoShortcut(event) {
  const isUndoRedo = event.ctrlKey || event.metaKey;
  if (!isUndoRedo) return false;

  const key = event.key.toLowerCase();
  if (key === "z" && !event.shiftKey) {
    event.preventDefault();
    undoLastAction();
    return true;
  }

  if ((key === "z" && event.shiftKey) || key === "y") {
    event.preventDefault();
    redoLastAction();
    return true;
  }

  return false;
}

function handleNumpadViewShortcut(event) {
  if (!event.code?.startsWith("Numpad")) return false;

  const code = event.code;
  if (["Numpad1", "Numpad3", "Numpad7", "Numpad9", "Numpad0"].includes(code)) {
    event.preventDefault();
  }

  if (code === "Numpad1") {
    setOrthogonalView(event.ctrlKey || event.metaKey ? "back" : "front");
    return true;
  }
  if (code === "Numpad3") {
    setOrthogonalView(event.ctrlKey || event.metaKey ? "left" : "right");
    return true;
  }
  if (code === "Numpad7") {
    setOrthogonalView(event.ctrlKey || event.metaKey ? "bottom" : "top");
    return true;
  }
  if (code === "Numpad9") {
    flipCameraView();
    return true;
  }
  if (code === "Numpad0") {
    fitCameraToObject(state.selected || state.modelRoot || state.grid);
    return true;
  }

  return false;
}

function setStatus(message, type = "") {
  statusBox.className = `status ${type}`.trim();
  statusBox.innerHTML = message;
}

function formatBytes(bytes) {
  if (bytes < 1024) return `${bytes} B`;
  if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;
  return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
}

function escapeHtml(value) {
  return String(value ?? "")
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;")
    .replaceAll("'", "&#039;");
}

function createNewAuthoringScene() {
  clearScene({ silent: true });
  ensureAuthoringRoot();
  state.currentFile = null;
  state.currentFileName = "from-scratch.glb";
  state.projectId = null;
  state.project = null;
  state.returnToViewer = false;
  state.history.undoStack.length = 0;
  state.history.redoStack.length = 0;
  setAuthoringTool("wall", { silent: true });
  updateAuthoringPlaneElevation();
  renderTree();
  renderProperties();
  updateUiEnabled();
  fitCameraToObject(state.grid);
  setStatus("Nouveau modèle prêt · Storey 0 actif · Wall actif en tracé continu · clique point par point, puis Stop ou Échap.", "ok");
}

function ensureAuthoringRoot() {
  if (state.modelRoot) return state.modelRoot;
  const root = new THREE.Group();
  root.name = "FromScratch_Model";
  state.scene.add(root);
  state.modelRoot = root;
  state.currentFileName = state.currentFileName || "from-scratch.glb";
  updateUiEnabled();
  return root;
}

function setAuthoringTool(tool, options = {}) {
  if (!["select", "wall", "partition", "slab", "door", "window", "roof", "stair"].includes(tool)) return;
  if (state.authoring.tool !== tool) cancelAuthoringDraw();
  state.authoring.tool = tool;
  if (tool !== "select" && state.edit.active) setEditMode(false);
  if (tool !== "select") ensureAuthoringRoot();
  if (tool === "roof") updateRoofPreviewFromSelection();
  else if (state.authoring.preview?.userData?.authoringType === "roof") removeAuthoringPreview();
  updateToolbarState();
  renderProperties();

  if (!options.silent) {
    if (tool === "wall") setStatus(`Outil Wall · preview live · Shift = guide 0°/45°/90° · alignement ${wallAlignmentLabel()} · snap visible grille/slab · Stop/Échap termine.`, "ok");
    else if (tool === "partition") setStatus("Outil Cloison · mur intérieur fin · tracé continu · Shift = guide 0°/45°/90° · Stop/Échap termine.", "ok");
    else if (tool === "slab") setStatus("Outil Slab · clic coin 1, clic coin opposé · rectangle contraint à la grille.", "ok");
    else if (tool === "door") setStatus("Outil Door · survole un mur, preview bleue/brune, clic pour créer la porte et découper le mur.", "ok");
    else if (tool === "window") setStatus("Outil Window · survole un mur, preview vitrée, clic pour créer la fenêtre et découper le mur.", "ok");
    else if (tool === "roof") setStatus("Outil Roof · sélectionne une slab : preview toiture · clique Roof from slab pour créer une toiture Flat/Shed/Gable.", "ok");
    else if (tool === "stair") setStatus("Outil Escalier · clic départ, clic arrivée/direction · largeur, marches et hauteur réglables dans le panneau.", "ok");
    else setStatus("Outil Select · sélection et transformations objet/édition.", "ok");
  }
}

function setWallAlignment(alignment) {
  const allowed = ["left", "center", "right"];
  state.authoring.wallAlignment = allowed.includes(alignment) ? alignment : "center";
  if (wallAlignmentSelect && wallAlignmentSelect.value !== state.authoring.wallAlignment) wallAlignmentSelect.value = state.authoring.wallAlignment;
  if (state.authoring.preview && state.authoring.tool === "wall") createOrUpdateAuthoringPreview();
  updateToolbarState();
  renderProperties();
  setStatus(`Alignement mur : ${wallAlignmentLabel()} · la preview montre l’épaisseur réelle avant validation.`, "ok");
}

function cycleWallAlignment(direction = 1) {
  const values = ["left", "center", "right"];
  const currentIndex = Math.max(0, values.indexOf(state.authoring.wallAlignment));
  const next = values[(currentIndex + direction + values.length) % values.length];
  setWallAlignment(next);
}

function wallAlignmentLabel(value = state.authoring.wallAlignment) {
  if (value === "left") return "face gauche";
  if (value === "right") return "face droite";
  return "axe central";
}

function isWallTraceTool(tool = state.authoring.tool) {
  return tool === "wall" || tool === "partition";
}

function authoringToolLabel(tool = state.authoring.tool) {
  if (tool === "wall") return "Wall";
  if (tool === "partition") return "Cloison";
  if (tool === "slab") return "Slab";
  if (tool === "door") return "Door";
  if (tool === "window") return "Window";
  if (tool === "roof") return "Roof";
  if (tool === "stair") return "Escalier";
  return "Select";
}

function setAuthoringSnap(enabled) {
  state.authoring.snap = Boolean(enabled);
  updateTransformSnapping();
  updateToolbarState();
  renderProperties();
  setStatus(`Snap grille ${state.authoring.snap ? "activé" : "désactivé"} · pas ${formatNumber(state.authoring.gridStep)} m.`, "ok");
}

function setGridStep(step) {
  const value = Number(step);
  state.authoring.gridStep = Number.isFinite(value) && value > 0 ? value : 0.1;
  updateTransformSnapping();
  updateGridHelperSize();
  updateToolbarState();
  renderProperties();
  setStatus(`Pas de grille : ${formatNumber(state.authoring.gridStep)} m.`, "ok");
}

function updateGridHelperSize() {
  if (!state.grid) return;
  const step = Math.max(0.005, state.authoring.gridStep || 0.1);
  const divisions = Math.min(4000, Math.max(2, Math.round(30 / step)));
  const oldGrid = state.grid;
  state.scene.remove(oldGrid);
  oldGrid.geometry?.dispose?.();
  oldGrid.material?.dispose?.();
  state.grid = new THREE.GridHelper(30, divisions, 0x3a4654, 0x202a34);
  state.grid.position.y = getActiveStoreyElevation();
  state.scene.add(state.grid);
  updateReferenceVisibilityAndElevation();
}

function resetAuthoringStoreys() {
  state.authoring.storeys = [{ id: "storey-0", name: "Storey 0", elevation: 0, height: Number(state.authoring.storeyHeight) || 3 }];
  state.authoring.activeStoreyId = "storey-0";
  updateAuthoringPlaneElevation();
}

function getActiveStorey() {
  const storeys = state.authoring.storeys?.length ? state.authoring.storeys : [{ id: "storey-0", name: "Storey 0", elevation: 0, height: 3 }];
  return storeys.find((storey) => storey.id === state.authoring.activeStoreyId) || storeys[0];
}

function getActiveStoreyElevation() {
  return Number(getActiveStorey()?.elevation || 0);
}

function getActiveStoreyIndex() {
  const storeys = state.authoring.storeys || [];
  return Math.max(0, storeys.findIndex((storey) => storey.id === state.authoring.activeStoreyId));
}

function getNextStoreyElevation() {
  const height = Math.max(0.1, Number(state.authoring.storeyHeight) || 3);
  const previousTop = (state.authoring.storeys || []).reduce((max, storey) => Math.max(max, Number(storey.elevation || 0)), 0);
  return previousTop + height;
}

function navigateStorey(direction) {
  const storeys = state.authoring.storeys || [];
  if (!storeys.length) return;
  const currentIndex = getActiveStoreyIndex();
  const nextIndex = THREE.MathUtils.clamp(currentIndex + Math.sign(direction || 0), 0, storeys.length - 1);
  if (nextIndex === currentIndex) {
    const label = direction > 0 ? "dernier étage" : "premier étage";
    setStatus(`Tu es déjà sur le ${label}.`, "warning");
    return;
  }
  setActiveStorey(storeys[nextIndex].id);
}

function createNewStorey() {
  ensureAuthoringRoot();
  cancelAuthoringDraw();
  cancelReferenceCalibration();

  const index = state.authoring.storeys.length;
  const height = Math.max(0.1, Number(state.authoring.storeyHeight) || 3);
  const storey = {
    id: `storey-${Date.now()}-${index}`,
    name: `Storey ${index}`,
    elevation: getNextStoreyElevation(),
    height,
  };

  state.authoring.storeys.push(storey);
  setActiveStorey(storey.id, { silent: true });
  setAuthoringTool("wall", { silent: true });
  markDirty();
  setStatus(`${escapeHtml(storey.name)} créé à ${formatNumber(storey.elevation)} m · la grille est verrouillée sur ce niveau.`, "ok");
}


function duplicateActiveStorey() {
  const sourceStorey = getActiveStorey();
  if (!sourceStorey) return;

  ensureAuthoringRoot();
  cancelAuthoringDraw();
  cancelReferenceCalibration();

  const sourceMeshes = state.meshes.filter((mesh) => (
    mesh?.parent
    && !mesh.userData?.__modelerOverlay
    && mesh.userData?.storeyId === sourceStorey.id
    && ["wall", "slab", "door", "window", "roof", "stair"].includes(mesh.userData?.authoringType)
  ));

  if (!sourceMeshes.length) {
    setStatus(`${escapeHtml(sourceStorey.name)} ne contient pas encore d’éléments auteur à dupliquer.`, "warning");
    return;
  }

  const index = state.authoring.storeys.length;
  const height = Math.max(0.1, Number(state.authoring.storeyHeight) || Number(sourceStorey.height) || 3);
  const targetStorey = {
    id: `storey-${Date.now()}-${index}`,
    name: `${sourceStorey.name} copie`,
    elevation: getNextStoreyElevation(),
    height,
  };

  const previousActiveId = state.authoring.activeStoreyId;
  state.authoring.storeys.push(targetStorey);
  state.authoring.activeStoreyId = targetStorey.id;
  updateAuthoringPlaneElevation();

  const root = ensureAuthoringRoot();
  const created = [];
  for (const mesh of sourceMeshes) {
    const copy = duplicateAuthoredMeshToActiveStorey(mesh, targetStorey);
    if (!copy) continue;
    root.add(copy);
    created.push(copy);
  }

  if (!created.length) {
    state.authoring.storeys = state.authoring.storeys.filter((storey) => storey.id !== targetStorey.id);
    state.authoring.activeStoreyId = previousActiveId;
    updateAuthoringPlaneElevation();
    setStatus("Duplication impossible : aucun élément compatible trouvé.", "warning");
    return;
  }

  indexMeshes(root);
  refreshAuthoredWallMiters();
  relinkOpeningMeshesForStorey(targetStorey.id);
  const indexed = created.map((mesh) => state.meshes.find((candidate) => candidate.uuid === mesh.uuid) || mesh);
  pushHistory({
    type: "createMeshes",
    label: `Duplicate ${sourceStorey.name}`,
    meshes: indexed,
    parent: root,
  });

  setActiveStorey(targetStorey.id, { silent: true });
  selectMesh(indexed[0] || null);
  renderTree();
  renderProperties();
  markDirty();
  updateUiEnabled();
  setStatus(`${escapeHtml(sourceStorey.name)} dupliqué vers ${escapeHtml(targetStorey.name)} · ${indexed.length} élément${indexed.length > 1 ? "s" : ""}.`, "ok");
}

function getAuthoredMeshesForStorey(storeyId) {
  return state.meshes.filter((mesh) => (
    mesh?.parent
    && !mesh.userData?.__modelerOverlay
    && mesh.userData?.storeyId === storeyId
    && ["wall", "slab", "door", "window", "roof", "stair"].includes(mesh.userData?.authoringType)
  ));
}

function captureChildRecord(object) {
  if (!object) return null;
  const parent = object.parent || null;
  return {
    mesh: object,
    parent,
    index: parent ? parent.children.indexOf(object) : -1,
  };
}

function addChildBackAt(record, fallbackParent = null) {
  if (!record?.mesh) return;
  const parent = record.parent || fallbackParent || state.modelRoot || ensureAuthoringRoot();
  if (!parent) return;
  if (!record.mesh.parent) parent.add(record.mesh);
  if (Number.isFinite(record.index) && record.index >= 0 && record.index < parent.children.length - 1) {
    const currentIndex = parent.children.indexOf(record.mesh);
    if (currentIndex >= 0) {
      parent.children.splice(currentIndex, 1);
      parent.children.splice(record.index, 0, record.mesh);
    }
  }
}

function detachReferencePlanForHistory(storeyId) {
  const ref = state.authoring.references.get(storeyId);
  if (!ref) return null;
  const parent = ref.mesh?.parent || null;
  const index = parent ? parent.children.indexOf(ref.mesh) : -1;
  if (ref.mesh?.parent) ref.mesh.parent.remove(ref.mesh);
  state.authoring.references.delete(storeyId);
  return { ref, parent, index };
}

function restoreReferencePlanFromHistory(record) {
  if (!record?.ref) return;
  state.authoring.references.set(record.ref.storeyId, record.ref);
  if (record.ref.mesh) {
    const parent = record.parent || state.scene;
    if (!record.ref.mesh.parent) parent.add(record.ref.mesh);
    if (Number.isFinite(record.index) && record.index >= 0 && record.index < parent.children.length - 1) {
      const currentIndex = parent.children.indexOf(record.ref.mesh);
      if (currentIndex >= 0) {
        parent.children.splice(currentIndex, 1);
        parent.children.splice(record.index, 0, record.ref.mesh);
      }
    }
  }
}

function getFallbackStoreyIdAfterDeletion(deletedIndex, preferredId = null) {
  const storeys = state.authoring.storeys || [];
  if (!storeys.length) return "storey-0";
  if (preferredId && storeys.some((storey) => storey.id === preferredId)) return preferredId;
  const fallbackIndex = THREE.MathUtils.clamp(Math.min(deletedIndex - 1, storeys.length - 1), 0, storeys.length - 1);
  return storeys[fallbackIndex]?.id || storeys[0]?.id;
}

function deleteActiveStorey() {
  if (!state.modelRoot) return;
  const storeys = state.authoring.storeys || [];
  const storey = getActiveStorey();
  if (!storey) return;
  if (storeys.length <= 1) {
    setStatus("Impossible de supprimer le dernier étage. Crée un autre storey avant de supprimer celui-ci.", "warning");
    return;
  }

  ensureAuthoringRoot();
  cancelAuthoringDraw();
  cancelReferenceCalibration();
  if (state.edit.active) setEditMode(false);

  const storeyIndex = getActiveStoreyIndex();
  const meshes = getAuthoredMeshesForStorey(storey.id);
  const ref = state.authoring.references.get(storey.id);
  const count = meshes.length + (ref ? 1 : 0);
  const message = `Supprimer ${storey.name} et ${count} élément${count > 1 ? "s" : ""} associé${count > 1 ? "s" : ""} ?\n\nCette action est annulable avec Ctrl/Cmd+Z.`;
  if (typeof window !== "undefined" && typeof window.confirm === "function" && !window.confirm(message)) return;

  const meshRecords = meshes.map(captureChildRecord).filter(Boolean);
  if (state.selected?.userData?.storeyId === storey.id) selectMesh(null);
  for (const record of meshRecords) {
    if (record.mesh?.parent) record.mesh.parent.remove(record.mesh);
  }

  const referenceRecord = detachReferencePlanForHistory(storey.id);
  state.authoring.storeys = storeys.filter((candidate) => candidate.id !== storey.id);
  const activeAfter = getFallbackStoreyIdAfterDeletion(storeyIndex);
  state.authoring.activeStoreyId = activeAfter;
  updateAuthoringPlaneElevation();

  if (state.modelRoot) {
    indexMeshes(state.modelRoot);
    refreshAuthoredWallMiters();
  }

  pushHistory({
    type: "deleteStorey",
    label: `Supprimer ${storey.name}`,
    storey: { ...storey },
    index: storeyIndex,
    activeBefore: storey.id,
    activeAfter,
    meshRecords,
    referenceRecord,
  });

  renderTree();
  renderProperties();
  markDirty();
  updateUiEnabled();
  setStatus(`${escapeHtml(storey.name)} supprimé · ${meshes.length} objet${meshes.length > 1 ? "s" : ""} retiré${meshes.length > 1 ? "s" : ""}. Ctrl/Cmd+Z pour annuler.`, "ok");
}

function duplicateAuthoredMeshToActiveStorey(mesh, targetStorey) {
  if (!mesh) return null;
  if (mesh.userData?.authoringType === "wall" && mesh.userData?.wallPath) {
    const data = mesh.userData.wallPath;
    const copy = createWallMesh(data.start.clone(), data.end.clone(), {
      prevPoint: data.prev?.clone?.() || null,
      nextPoint: data.next?.clone?.() || null,
      alignment: data.alignment || state.authoring.wallAlignment,
      kind: data.kind || "wall",
      thickness: data.thickness,
      height: data.height,
      openings: Array.isArray(data.openings) ? data.openings.map((opening) => {
        const copy = cloneOpening(opening);
        const deltaY = targetStorey.elevation - Number(mesh.userData?.storeyElevation || data.baseElevation || 0);
        if (Number.isFinite(Number(copy.floorElevation))) copy.floorElevation = Number(copy.floorElevation) + deltaY;
        return copy;
      }) : [],
    });
    if (!copy) return null;
    copy.name = `${mesh.name || "Wall"}_copy`;
    copy.userData.storeyId = targetStorey.id;
    copy.userData.storeyName = targetStorey.name;
    copy.userData.storeyElevation = targetStorey.elevation;
    copy.userData.wallPath.baseElevation = targetStorey.elevation;
    copy.userData.wallPath.storeyId = targetStorey.id;
    copy.userData.wallPath.storeyName = targetStorey.name;
    copy.position.y = targetStorey.elevation;
    if (state.xray.active) applyXrayToMesh(copy);
    return copy;
  }

  if (mesh.userData?.authoringType === "slab") {
    const points = slabBoundaryPoints(mesh);
    if (!points?.length) return null;
    const min = points.reduce((acc, point) => {
      acc.x = Math.min(acc.x, point.x);
      acc.z = Math.min(acc.z, point.z);
      return acc;
    }, new THREE.Vector3(Infinity, targetStorey.elevation, Infinity));
    const max = points.reduce((acc, point) => {
      acc.x = Math.max(acc.x, point.x);
      acc.z = Math.max(acc.z, point.z);
      return acc;
    }, new THREE.Vector3(-Infinity, targetStorey.elevation, -Infinity));
    const copy = createSlabMesh(
      new THREE.Vector3(min.x, targetStorey.elevation, min.z),
      new THREE.Vector3(max.x, targetStorey.elevation, max.z)
    );
    if (!copy) return null;
    copy.name = `${mesh.name || "Slab"}_copy`;
    copy.userData.storeyId = targetStorey.id;
    copy.userData.storeyName = targetStorey.name;
    copy.userData.storeyElevation = targetStorey.elevation;
    if (state.xray.active) applyXrayToMesh(copy);
    return copy;
  }


  if (mesh.userData?.authoringType === "roof" && mesh.userData?.roofData) {
    const oldActiveId = state.authoring.activeStoreyId;
    state.authoring.activeStoreyId = targetStorey.id;
    const data = mesh.userData.roofData;
    const fakeSlab = {
      userData: {
        authoringType: "slab",
        storeyId: targetStorey.id,
        storeyName: targetStorey.name,
        storeyElevation: targetStorey.elevation,
        slabBoundary: {
          minX: data.minX + Number(data.overhang || 0),
          maxX: data.maxX - Number(data.overhang || 0),
          minZ: data.minZ + Number(data.overhang || 0),
          maxZ: data.maxZ - Number(data.overhang || 0),
          elevation: targetStorey.elevation,
        },
      },
    };
    const previous = {
      roofType: state.authoring.roofType,
      roofPitch: state.authoring.roofPitch,
      roofThickness: state.authoring.roofThickness,
      roofOverhang: state.authoring.roofOverhang,
      roofEavesHeight: state.authoring.roofEavesHeight,
      roofRidgeDirection: state.authoring.roofRidgeDirection,
    };
    state.authoring.roofType = data.type || previous.roofType;
    state.authoring.roofPitch = Number(data.pitch ?? previous.roofPitch);
    state.authoring.roofThickness = Number(data.thickness ?? previous.roofThickness);
    state.authoring.roofOverhang = Number(data.overhang ?? previous.roofOverhang);
    state.authoring.roofEavesHeight = Number(data.eavesHeight ?? previous.roofEavesHeight);
    state.authoring.roofRidgeDirection = data.ridgeDirection || previous.roofRidgeDirection;
    const copy = createRoofMeshFromSlab(fakeSlab);
    Object.assign(state.authoring, previous);
    state.authoring.activeStoreyId = oldActiveId;
    if (!copy) return null;
    copy.name = `${mesh.name || "Roof"}_copy`;
    if (state.xray.active) applyXrayToMesh(copy);
    return copy;
  }

  if (mesh.userData?.authoringType === "stair" && mesh.userData?.stairData) {
    const data = mesh.userData.stairData;
    const oldActiveId = state.authoring.activeStoreyId;
    state.authoring.activeStoreyId = targetStorey.id;
    const start = data.start?.clone?.() || new THREE.Vector3();
    const end = data.end?.clone?.() || start.clone().add(new THREE.Vector3(Number(data.run) || 2.4, 0, 0));
    start.y = targetStorey.elevation;
    end.y = targetStorey.elevation;
    const copy = createStairMesh(start, end, {
      width: Number(data.width ?? mesh.userData?.dimensions?.width ?? state.authoring.stairWidth),
      steps: Number(data.steps ?? mesh.userData?.dimensions?.steps ?? state.authoring.stairSteps),
      rise: Number(data.rise ?? mesh.userData?.dimensions?.rise ?? state.authoring.stairRise),
    });
    state.authoring.activeStoreyId = oldActiveId;
    if (!copy) return null;
    copy.name = `${mesh.name || "Stair"}_copy`;
    copy.userData.storeyId = targetStorey.id;
    copy.userData.storeyName = targetStorey.name;
    copy.userData.storeyElevation = targetStorey.elevation;
    copy.userData.stairData.storeyId = targetStorey.id;
    copy.userData.stairData.storeyName = targetStorey.name;
    copy.userData.stairData.baseElevation = targetStorey.elevation;
    if (state.xray.active) applyXrayToMesh(copy);
    return copy;
  }

  if (["door", "window"].includes(mesh.userData?.authoringType)) {
    const deltaY = targetStorey.elevation - Number(mesh.userData?.storeyElevation || 0);
    const copy = mesh.clone(false);
    copy.geometry = mesh.geometry?.clone?.() || null;
    copy.material = cloneMaterial(mesh.material);
    copy.name = `${mesh.name || openingToolLabel(mesh.userData.authoringType)}_copy`;
    copy.position.copy(mesh.position);
    copy.position.y += deltaY;
    copy.quaternion.copy(mesh.quaternion);
    copy.scale.copy(mesh.scale);
    copy.userData = JSON.parse(JSON.stringify(mesh.userData || {}));
    delete copy.userData.__modelerId;
    copy.userData.storeyId = targetStorey.id;
    copy.userData.storeyName = targetStorey.name;
    copy.userData.storeyElevation = targetStorey.elevation;

    // The copied wall receives a new local modeler id after indexMeshes(). Until
    // then, keeping the source wallId on the copied opening is dangerous: direct
    // delete/edit operations would target the source storey. Keep the semantic
    // opening id and force getOpeningLinkForMesh() to resolve the host wall by
    // storey + proximity/opening id.
    if (copy.userData.opening) {
      copy.userData.opening = { ...copy.userData.opening };
      delete copy.userData.opening.wallId;
    }

    if (state.xray.active) applyXrayToMesh(copy);
    return copy;
  }

  return null;
}

function setActiveStorey(storeyId, options = {}) {
  const storey = state.authoring.storeys.find((candidate) => candidate.id === storeyId);
  if (!storey) return;
  cancelAuthoringDraw();
  cancelReferenceCalibration();
  state.authoring.activeStoreyId = storey.id;
  updateAuthoringPlaneElevation();
  updateToolbarState();
  renderProperties();
  if (!options.silent) setStatus(`${escapeHtml(storey.name)} actif · grille à ${formatNumber(storey.elevation)} m. Les nouveaux éléments seront créés sur cet étage. PageUp/PageDown navigue entre étages.`, "ok");
}

function updateAuthoringPlaneElevation() {
  const elevation = getActiveStoreyElevation();
  groundPlane.constant = -elevation;
  if (state.grid) state.grid.position.y = elevation;
  updateStoreySelect();
  updateReferenceVisibilityAndElevation();
}

function updateStoreySelect() {
  if (!storeySelect) return;
  const current = state.authoring.activeStoreyId;
  storeySelect.innerHTML = state.authoring.storeys.map((storey) => (
    `<option value="${escapeHtml(storey.id)}">${escapeHtml(storey.name)} · ${formatNumber(storey.elevation)}m</option>`
  )).join("");
  storeySelect.value = current;
}

function getActiveReferencePlan() {
  return state.authoring.references.get(state.authoring.activeStoreyId) || null;
}

async function loadReferencePlanFile(file) {
  if (!file.type?.startsWith("image/")) throw new Error("Le fichier doit être une image.");
  ensureAuthoringRoot();
  cancelAuthoringDraw();
  cancelReferenceCalibration();

  const storey = getActiveStorey();
  const url = URL.createObjectURL(file);
  state.objectUrls.add(url);

  const imageInfo = await loadImageInfo(url);
  const texture = await new THREE.TextureLoader().loadAsync(url);
  texture.colorSpace = THREE.SRGBColorSpace;

  const maxSide = 12;
  const aspect = imageInfo.width > 0 && imageInfo.height > 0 ? imageInfo.width / imageInfo.height : 1;
  const initialWidth = aspect >= 1 ? maxSide : maxSide * aspect;
  const initialDepth = aspect >= 1 ? maxSide / aspect : maxSide;

  const geometry = new THREE.PlaneGeometry(initialWidth, initialDepth);
  const material = new THREE.MeshBasicMaterial({
    map: texture,
    transparent: true,
    opacity: 0.62,
    side: THREE.DoubleSide,
    depthWrite: false,
  });
  const mesh = new THREE.Mesh(geometry, material);
  mesh.name = `ReferencePlan_${storey.name}`;
  mesh.rotation.x = -Math.PI / 2;
  mesh.position.set(0, storey.elevation + 0.004, 0);
  mesh.renderOrder = -5;
  mesh.userData.__modelerOverlay = true;
  mesh.userData.referencePlan = true;

  const existing = state.authoring.references.get(storey.id);
  if (existing) disposeReferencePlan(existing);

  const ref = {
    storeyId: storey.id,
    fileName: file.name,
    url,
    mesh,
    baseWidth: initialWidth,
    baseDepth: initialDepth,
    scale: 1,
    imageWidth: imageInfo.width,
    imageHeight: imageInfo.height,
  };

  state.authoring.references.set(storey.id, ref);
  state.scene.add(mesh);
  updateReferenceVisibilityAndElevation();
  renderProperties();
  updateUiEnabled();
  setStatus(`Plan 2D importé sur ${escapeHtml(storey.name)} · utilise “Scale plan” pour le mettre à l’échelle avec 2 points.`, "ok");
}

function loadImageInfo(url) {
  return new Promise((resolve, reject) => {
    const img = new Image();
    img.onload = () => resolve({ width: img.naturalWidth || img.width || 1, height: img.naturalHeight || img.height || 1 });
    img.onerror = () => reject(new Error("Impossible de lire l’image."));
    img.src = url;
  });
}

function updateReferenceVisibilityAndElevation() {
  const activeId = state.authoring.activeStoreyId;
  for (const ref of state.authoring.references.values()) {
    if (!ref.mesh) continue;
    const storey = state.authoring.storeys.find((candidate) => candidate.id === ref.storeyId);
    ref.mesh.visible = ref.storeyId === activeId;
    if (storey) ref.mesh.position.y = Number(storey.elevation || 0) + 0.004;
  }
}

function disposeReferencePlan(ref) {
  if (!ref) return;
  if (ref.mesh?.parent) ref.mesh.parent.remove(ref.mesh);
  disposeObject(ref.mesh);
  if (ref.url) {
    URL.revokeObjectURL(ref.url);
    state.objectUrls.delete(ref.url);
  }
}

function removeAllReferencePlans() {
  for (const ref of state.authoring.references.values()) disposeReferencePlan(ref);
  state.authoring.references.clear();
  cancelReferenceCalibration();
}

function beginReferenceCalibration() {
  const ref = getActiveReferencePlan();
  if (!ref?.mesh) {
    setStatus("Importe d’abord un Plan 2D pour l’étage actif.", "warning");
    return;
  }
  cancelAuthoringDraw();
  setAuthoringTool("select", { silent: true });
  state.authoring.calibration.active = true;
  state.authoring.calibration.start = null;
  state.authoring.calibration.current = null;
  removeReferenceCalibrationLine();
  updateToolbarState();
  setStatus("Scale plan actif · clique le premier point sur le plan, puis le second, puis saisis la distance réelle en mètres.", "ok");
}

function cancelReferenceCalibration() {
  if (!state.authoring.calibration.active && !state.authoring.calibration.start) return;
  state.authoring.calibration.active = false;
  state.authoring.calibration.start = null;
  state.authoring.calibration.current = null;
  removeReferenceCalibrationLine();
  updateToolbarState();
}

function handleReferenceCalibrationClick(event) {
  const ref = getActiveReferencePlan();
  if (!ref?.mesh) {
    cancelReferenceCalibration();
    return;
  }
  const point = pointerToGroundPoint(event, { snap: false });
  if (!point) return;

  if (!state.authoring.calibration.start) {
    state.authoring.calibration.start = point.clone();
    state.authoring.calibration.current = point.clone();
    updateReferenceCalibrationLine(point);
    setStatus("Premier point de calibration posé · clique le second point sur le plan.", "ok");
    return;
  }

  const start = state.authoring.calibration.start.clone();
  const end = point.clone();
  const measured = distanceOnPlan(start, end);
  if (measured < 1e-5) {
    setStatus("Distance de calibration trop courte.", "warning");
    return;
  }

  const entered = window.prompt(`Distance réelle entre les 2 points, en mètres :`, measured.toFixed(2));
  if (entered === null) {
    cancelReferenceCalibration();
    setStatus("Calibration du plan annulée.", "warning");
    return;
  }

  const realDistance = Number(String(entered).replace(",", "."));
  if (!Number.isFinite(realDistance) || realDistance <= 0) {
    setStatus("Distance invalide. Relance Scale plan et saisis une valeur positive en mètres.", "warning");
    return;
  }

  const factor = realDistance / measured;
  applyReferencePlanScale(ref, factor, start);
  cancelReferenceCalibration();
  renderProperties();
  markDirty();
  setStatus(`Plan mis à l’échelle · ${formatNumber(measured)} m écran → ${formatNumber(realDistance)} m réel · facteur x${factor.toFixed(4)}.`, "ok");
}

function updateReferenceCalibrationPreviewFromEvent(event) {
  if (!state.authoring.calibration.active || !state.authoring.calibration.start) return;
  const point = pointerToGroundPoint(event, { snap: false });
  if (!point) return;
  state.authoring.calibration.current = point.clone();
  updateReferenceCalibrationLine(point);
}

function updateReferenceCalibrationLine(current) {
  const start = state.authoring.calibration.start;
  if (!start || !current) return;
  removeReferenceCalibrationLine();
  const elevation = getActiveStoreyElevation() + 0.035;
  const geometry = new THREE.BufferGeometry().setFromPoints([
    new THREE.Vector3(start.x, elevation, start.z),
    new THREE.Vector3(current.x, elevation, current.z),
  ]);
  const line = new THREE.Line(geometry, referenceCalibrationMaterial.clone());
  line.name = "Reference scale line";
  line.userData.__modelerOverlay = true;
  line.renderOrder = 50;
  state.authoring.calibration.line = line;
  state.scene.add(line);
}

function removeReferenceCalibrationLine() {
  const line = state.authoring.calibration.line;
  if (!line) return;
  if (line.parent) line.parent.remove(line);
  disposeObject(line);
  state.authoring.calibration.line = null;
}

function distanceOnPlan(a, b) {
  return Math.hypot(b.x - a.x, b.z - a.z);
}

function applyReferencePlanScale(ref, factor, anchorWorld) {
  if (!ref?.mesh || !Number.isFinite(factor) || factor <= 0) return;
  const mesh = ref.mesh;
  mesh.updateMatrixWorld(true);
  const anchorLocal = mesh.worldToLocal(anchorWorld.clone());
  mesh.scale.x *= factor;
  mesh.scale.y *= factor;
  mesh.updateMatrixWorld(true);
  const anchorAfter = mesh.localToWorld(anchorLocal.clone());
  mesh.position.x += anchorWorld.x - anchorAfter.x;
  mesh.position.z += anchorWorld.z - anchorAfter.z;
  mesh.position.y = getActiveStoreyElevation() + 0.004;
  ref.scale *= factor;
}

function isDrawingAuthoringTool() {
  return !state.edit.active && ["wall", "partition", "slab", "door", "window", "stair"].includes(state.authoring.tool);
}

function isOpeningTool(tool = state.authoring.tool) {
  return tool === "door" || tool === "window";
}

function handleAuthoringClick(event) {
  if (isOpeningTool()) {
    commitOpeningPlacement(event);
    return;
  }

  const point = pointerToGroundPoint(event);
  if (!point) {
    setStatus("Impossible de projeter le clic sur la grille. Change légèrement l’orientation caméra.", "warning");
    return;
  }

  ensureAuthoringRoot();

  if (!state.authoring.drawStart) {
    state.authoring.wallChainLastMesh = null;
    state.authoring.drawStart = point.clone();
    state.authoring.drawCurrent = point.clone();
    createOrUpdateAuthoringPreview();
    const label = isWallTraceTool() ? (state.authoring.tool === "partition" ? "cloison" : "mur") : state.authoring.tool === "stair" ? "escalier" : "dalle";
    setStatus(`Point 1 du ${label} posé : ${formatVector(point)} · clique le second point. Maintiens Shift pour guider à 0°/45°/90°.`, "ok");
    return;
  }

  state.authoring.drawCurrent = point.clone();
  commitAuthoringPrimitive();
}

function updateAuthoringPreviewFromEvent(event) {
  if (isOpeningTool()) {
    updateOpeningPreviewFromEvent(event);
    return;
  }

  const point = pointerToGroundPoint(event);
  if (!point) return;
  if (!state.authoring.drawStart) {
    removeAuthoringPreview();
    return;
  }
  state.authoring.drawCurrent = point.clone();
  createOrUpdateAuthoringPreview();
}

function pointerToGroundPoint(event, options = {}) {
  const elevation = getActiveStoreyElevation();
  groundPlane.constant = -elevation;
  const rect = state.renderer.domElement.getBoundingClientRect();
  state.pointer.x = ((event.clientX - rect.left) / rect.width) * 2 - 1;
  state.pointer.y = -((event.clientY - rect.top) / rect.height) * 2 + 1;
  state.raycaster.setFromCamera(state.pointer, state.camera);
  const point = new THREE.Vector3();
  const hit = state.raycaster.ray.intersectPlane(groundPlane, point);
  if (!hit) {
    clearAuthoringSnapFeedback();
    return null;
  }

  const shouldSnap = options.snap ?? state.authoring.snap;
  if (shouldSnap) snapAuthoringPoint(point, options);
  else setAuthoringSnapInfo({ type: "free", label: "Libre", point: point.clone() });

  applyWallAngleGuideIfNeeded(point, event, options);
  point.y = elevation;

  if (options.feedback !== false) {
    updateAuthoringSnapMarker(point);
    updateSnapHud(event);
  }

  return point;
}

function applyWallAngleGuideIfNeeded(point, event, options = {}) {
  if (options.angleGuide === false) return point;
  if (!event?.shiftKey) return point;
  if (!isWallTraceTool() && state.authoring.tool !== "stair") return point;
  if (!state.authoring.drawStart) return point;
  if (state.authoring.calibration.active || isOpeningTool()) return point;

  const start = state.authoring.drawStart;
  const dx = point.x - start.x;
  const dz = point.z - start.z;
  const distance = Math.hypot(dx, dz);
  if (distance < 1e-6) return point;

  const rawAngle = Math.atan2(dz, dx);
  const stepAngle = Math.PI / 4;
  const snappedAngle = Math.round(rawAngle / stepAngle) * stepAngle;
  const cos = Math.cos(snappedAngle);
  const sin = Math.sin(snappedAngle);
  const signX = Math.abs(cos) < 1e-6 ? 0 : Math.sign(cos);
  const signZ = Math.abs(sin) < 1e-6 ? 0 : Math.sign(sin);
  const grid = Math.max(0.0001, Number(state.authoring.gridStep) || 0.1);

  let component;
  if (signX && signZ) component = Math.max(Math.abs(dx), Math.abs(dz));
  else if (signX) component = Math.abs(dx);
  else component = Math.abs(dz);

  if (state.authoring.snap) component = Math.max(grid, Math.round(component / grid) * grid);

  point.x = start.x + signX * component;
  point.z = start.z + signZ * component;
  point.y = getActiveStoreyElevation();

  const degrees = normalizeGuideAngle(Math.round(THREE.MathUtils.radToDeg(snappedAngle)));
  const previousLabel = state.authoring.snapInfo?.label || (state.authoring.snap ? `Grille ${formatNumber(grid)} m` : "Libre");
  setAuthoringSnapInfo({
    type: "angle-guide",
    label: `Guide ${degrees}° · ${previousLabel}`,
    point: point.clone(),
  });
  return point;
}

function normalizeGuideAngle(degrees) {
  let angle = degrees % 180;
  if (angle < 0) angle += 180;
  return angle === 135 ? -45 : angle;
}

function snapAuthoringPoint(point, options = {}) {
  const raw = point.clone();

  // Architectural drafting affordance: when tracing walls, prefer clean slab
  // boundaries/corners over raw grid cells. This lets the preview show whether
  // the wall will really hug a slab edge before the user commits the click.
  if (options.slabEdges !== false && state.authoring.tool === "wall") {
    const slabSnap = nearestSlabBoundarySnap(raw);
    if (slabSnap) {
      point.copy(slabSnap.point);
      point.y = getActiveStoreyElevation();
      setAuthoringSnapInfo({
        type: slabSnap.kind,
        label: slabSnap.kind === "slab-corner" ? "Coin slab" : "Bord slab",
        point: point.clone(),
      });
      return point;
    }
  }

  snapPointToGrid(point);
  setAuthoringSnapInfo({ type: "grid", label: `Grille ${formatNumber(state.authoring.gridStep)} m`, point: point.clone() });
  return point;
}

function setAuthoringSnapInfo(info) {
  state.authoring.snapInfo = {
    type: info?.type || "none",
    label: info?.label || "",
    point: info?.point?.clone?.() || null,
  };
}

function snapPointToGrid(point) {
  const step = Math.max(0.0001, Number(state.authoring.gridStep) || 0.1);
  point.x = Math.round(point.x / step) * step;
  point.z = Math.round(point.z / step) * step;
  point.y = getActiveStoreyElevation();
  return point;
}

function nearestSlabBoundarySnap(point) {
  const step = Math.max(0.0001, Number(state.authoring.gridStep) || 0.1);
  const threshold = Math.max(step * 2.5, 0.06);
  let best = null;

  for (const segment of activeStoreySlabBoundarySegments()) {
    for (const corner of [segment.a, segment.b]) {
      const cornerDistance = Math.hypot(point.x - corner.x, point.z - corner.z);
      if (cornerDistance <= threshold && (!best || cornerDistance < best.distance)) {
        best = { distance: cornerDistance, point: corner.clone(), kind: "slab-corner" };
      }
    }

    const projected = closestPointOnSegment2D(point, segment.a, segment.b);
    const distance = Math.hypot(point.x - projected.x, point.z - projected.z);
    if (distance <= threshold && (!best || distance < best.distance)) {
      best = { distance, point: projected, kind: "slab-edge" };
    }
  }

  return best || null;
}

function nearestSlabBoundaryPoint(point) {
  return nearestSlabBoundarySnap(point)?.point || null;
}

function activeStoreySlabBoundarySegments() {
  const activeStoreyId = getActiveStorey()?.id;
  const segments = [];

  for (const mesh of state.meshes) {
    if (mesh.userData?.authoringType !== "slab") continue;
    if (activeStoreyId && mesh.userData?.storeyId && mesh.userData.storeyId !== activeStoreyId) continue;

    const points = slabBoundaryPoints(mesh);
    if (!points?.length) continue;
    const [p1, p2, p3, p4] = points;
    segments.push({ a: p1, b: p2 }, { a: p2, b: p3 }, { a: p3, b: p4 }, { a: p4, b: p1 });
  }

  return segments;
}

function closestPointOnSegment2D(point, a, b) {
  const abx = b.x - a.x;
  const abz = b.z - a.z;
  const denom = abx * abx + abz * abz;
  if (denom < 1e-12) return a.clone();
  const t = THREE.MathUtils.clamp(((point.x - a.x) * abx + (point.z - a.z) * abz) / denom, 0, 1);
  return new THREE.Vector3(a.x + abx * t, getActiveStoreyElevation(), a.z + abz * t);
}

function updateAuthoringSnapMarker(point) {
  if (!isDrawingAuthoringTool() && !state.authoring.calibration.active) {
    removeAuthoringSnapMarker();
    return;
  }

  if (!state.authoring.snapMarker) {
    const geometry = new THREE.RingGeometry(0.07, 0.105, 28);
    const marker = new THREE.Mesh(geometry, authoringSnapMarkerMaterial.clone());
    marker.rotation.x = -Math.PI / 2;
    marker.renderOrder = 30;
    marker.userData.__modelerOverlay = true;
    state.authoring.snapMarker = marker;
    state.scene.add(marker);
  }

  state.authoring.snapMarker.position.set(point.x, getActiveStoreyElevation() + 0.012, point.z);
  state.authoring.snapMarker.visible = true;
}

function removeAuthoringSnapMarker() {
  const marker = state.authoring.snapMarker;
  if (!marker) return;
  state.scene.remove(marker);
  disposeObject(marker);
  state.authoring.snapMarker = null;
}

function updateSnapHud(event) {
  if (!snapHud || !event || !isDrawingAuthoringTool()) return;
  const info = state.authoring.snapInfo || {};
  const alignment = state.authoring.tool === "wall" ? ` · ${wallAlignmentLabel()}` : state.authoring.tool === "partition" ? " · cloison intérieure" : "";
  const point = info.point;
  const coords = point ? ` · X ${formatNumber(point.x)} · Z ${formatNumber(point.z)}` : "";
  snapHud.textContent = `${info.label || "Libre"}${alignment}${coords}`;
  snapHud.className = `snap-hud visible ${info.type || "none"}`;
  const rect = container.getBoundingClientRect();
  const x = THREE.MathUtils.clamp(event.clientX - rect.left + 14, 8, Math.max(8, rect.width - 260));
  const y = THREE.MathUtils.clamp(event.clientY - rect.top + 14, 8, Math.max(8, rect.height - 44));
  snapHud.style.left = `${x}px`;
  snapHud.style.top = `${y}px`;
}

function clearSnapHud() {
  if (!snapHud) return;
  snapHud.classList.remove("visible", "grid", "slab-edge", "slab-corner", "wall", "free");
  snapHud.textContent = "";
}

function clearAuthoringSnapFeedback() {
  setAuthoringSnapInfo({ type: "none", label: "", point: null });
  removeAuthoringSnapMarker();
  clearSnapHud();
}

function createOrUpdateAuthoringPreview() {
  removeAuthoringPreview();

  if (isOpeningTool()) {
    const placement = state.authoring.openingPlacement;
    if (!placement) return;
    const mesh = createOpeningMesh(placement, state.authoring.tool, { preview: true });
    if (!mesh) return;
    mesh.userData.__modelerOverlay = true;
    mesh.name = `${openingToolLabel(state.authoring.tool)} preview`;
    state.authoring.preview = mesh;
    state.scene.add(mesh);
    return;
  }

  const start = state.authoring.drawStart;
  const end = state.authoring.drawCurrent;
  if (!start || !end) return;

  const mesh = isWallTraceTool()
    ? createWallMesh(start, end, {
        preview: true,
        prevPoint: state.authoring.wallChainLastMesh?.userData?.wallPath?.start || null,
        alignment: state.authoring.tool === "partition" ? "center" : state.authoring.wallAlignment,
        kind: state.authoring.tool === "partition" ? "partition" : "wall",
      })
    : state.authoring.tool === "stair"
      ? createStairMesh(start, end, { preview: true })
      : createSlabMesh(start, end, { preview: true });

  if (!mesh) return;
  mesh.userData.__modelerOverlay = true;
  mesh.name = "Authoring preview";
  state.authoring.preview = mesh;
  state.scene.add(mesh);
}

function removeAuthoringPreview() {
  const preview = state.authoring.preview;
  if (!preview) return;
  state.scene.remove(preview);
  disposeObject(preview);
  state.authoring.preview = null;
}

function cancelAuthoringDraw() {
  state.authoring.drawStart = null;
  state.authoring.drawCurrent = null;
  state.authoring.wallChainLastMesh = null;
  state.authoring.openingPlacement = null;
  removeAuthoringPreview();
  clearAuthoringSnapFeedback();
  updateToolbarState();
}

function stopAuthoringTool(options = {}) {
  const wasDrawing = isDrawingAuthoringTool() || Boolean(state.authoring.drawStart);
  cancelAuthoringDraw();
  setAuthoringTool("select", { silent: true });
  if (!options.silent && wasDrawing) {
    setStatus("Tracé terminé · outil Select actif.", "ok");
  }
}


function updateOpeningPreviewFromEvent(event) {
  const point = pointerToGroundPoint(event, { snap: false, feedback: false });
  if (!point) {
    state.authoring.openingPlacement = null;
    removeAuthoringPreview();
    clearAuthoringSnapFeedback();
    return;
  }

  const placement = nearestWallPlacement(point);
  if (!placement) {
    state.authoring.openingPlacement = null;
    removeAuthoringPreview();
    setAuthoringSnapInfo({ type: "free", label: "Aucun mur proche", point: point.clone() });
    updateSnapHud(event);
    removeAuthoringSnapMarker();
    return;
  }

  state.authoring.openingPlacement = placement;
  setAuthoringSnapInfo({
    type: "wall",
    label: `Mur ${placement.wall.name || ""}`.trim(),
    point: placement.point.clone(),
  });
  updateAuthoringSnapMarker(placement.point);
  updateSnapHud(event);
  createOrUpdateAuthoringPreview();
}

function commitOpeningPlacement(event) {
  const point = pointerToGroundPoint(event, { snap: false, feedback: false });
  if (!point) return;
  const placement = nearestWallPlacement(point);
  if (!placement) {
    setStatus(`${openingToolLabel(state.authoring.tool)} : aucun mur proche. Survole une face/axe de mur pour placer l’ouverture.`, "warning");
    return;
  }

  const result = createOpeningOnWall(placement, state.authoring.tool);
  if (!result) {
    setStatus("Ouverture impossible : point trop proche d’une extrémité ou dimensions invalides.", "warning");
    return;
  }

  const { wall, mesh, opening } = result;
  const root = ensureAuthoringRoot();
  root.add(mesh);
  refreshWallMeshGeometry(wall);
  indexMeshes(root);
  const indexed = state.meshes.find((candidate) => candidate.uuid === mesh.uuid) || mesh;
  pushHistory({
    type: "createOpening",
    label: `Create ${openingToolLabel(state.authoring.tool)}`,
    wallId: wall.userData.__modelerId,
    opening: cloneOpening(opening),
    mesh: indexed,
    parent: root,
  });
  selectMesh(indexed);
  removeAuthoringPreview();
  state.authoring.openingPlacement = null;
  markDirty();
  renderTree();
  renderProperties();
  updateUiEnabled();
  setStatus(`${openingToolLabel(state.authoring.tool)} créé · le mur ${escapeHtml(wall.name || "")} est découpé.`, "ok");
}

function nearestWallPlacement(point) {
  const activeStoreyId = state.authoring.activeStoreyId;
  const walls = state.meshes.filter((mesh) => (
    mesh.userData?.authoringType === "wall"
    && mesh.userData?.wallPath
    && (!activeStoreyId || mesh.userData?.storeyId === activeStoreyId)
  ));
  const step = Math.max(0.0001, Number(state.authoring.gridStep) || 0.1);
  let best = null;

  for (const wall of walls) {
    const data = wall.userData.wallPath;
    const start = data.start;
    const end = data.end;
    const length = Math.hypot(end.x - start.x, end.z - start.z);
    if (length < 1e-6) continue;

    const dir = new THREE.Vector3((end.x - start.x) / length, 0, (end.z - start.z) / length);
    const normal2 = new THREE.Vector2(-dir.z, dir.x);
    const offset = wallCenterOffset(data.thickness, data.alignment || "center");
    const localX = point.x - start.x;
    const localZ = point.z - start.z;
    const distanceAlong = THREE.MathUtils.clamp(localX * dir.x + localZ * dir.z, 0, length);
    const projected = new THREE.Vector3(start.x + dir.x * distanceAlong, getActiveStoreyElevation(), start.z + dir.z * distanceAlong);
    const centerPoint = new THREE.Vector3(projected.x + normal2.x * offset, getActiveStoreyElevation(), projected.z + normal2.y * offset);
    const distance = Math.hypot(point.x - centerPoint.x, point.z - centerPoint.z);
    const threshold = Math.max(step * 3, Math.max(0.18, Number(data.thickness || state.authoring.wallThickness) * 1.8));
    if (distance <= threshold && (!best || distance < best.distance)) {
      best = {
        wall,
        wallData: data,
        point: centerPoint,
        linePoint: projected,
        offset: distanceAlong,
        t: length > 0 ? distanceAlong / length : 0,
        length,
        dir,
        normal: new THREE.Vector3(normal2.x, 0, normal2.y),
        centerOffset: offset,
        distance,
      };
    }
  }

  return best;
}

function createOpeningOnWall(placement, tool) {
  const wall = placement.wall;
  const data = wall?.userData?.wallPath;
  if (!wall || !data) return null;
  const defaults = openingDefaults(tool);
  const width = defaults.width;
  const height = defaults.height;
  const sill = defaults.sill;
  const margin = Math.max(0.05, Number(data.thickness || state.authoring.wallThickness) * 0.35);
  const length = Math.hypot(data.end.x - data.start.x, data.end.z - data.start.z);
  const half = width * 0.5;
  const offset = THREE.MathUtils.clamp(placement.offset, margin + half, Math.max(margin + half, length - margin - half));
  if (offset - half < margin || offset + half > length - margin) return null;

  const point = pointAlongWallData(data, offset, true);
  const floorElevation = openingFloorElevationForWall(wall, point);
  const effectiveSill = Math.max(0, floorElevation - Number(data.baseElevation ?? getActiveStoreyElevation())) + sill;
  if (effectiveSill + height > Number(data.height || state.authoring.wallHeight) - 0.02) return null;

  const opening = {
    id: `opening-${Date.now()}-${Math.round(Math.random() * 1e6)}`,
    type: tool,
    offset,
    width,
    height,
    sill,
    floorElevation,
  };
  data.openings = Array.isArray(data.openings) ? data.openings : [];
  data.openings.push(opening);
  const mesh = createOpeningMesh({ ...placement, offset, point }, tool, { opening, wall });
  if (!mesh) {
    data.openings = data.openings.filter((item) => item.id !== opening.id);
    return null;
  }
  return { wall, opening, mesh };
}

function createOpeningMesh(placement, tool, options = {}) {
  const data = placement.wallData || placement.wall?.userData?.wallPath;
  if (!data) return null;
  const defaults = openingDefaults(tool);
  const width = options.opening?.width ?? defaults.width;
  const height = options.opening?.height ?? defaults.height;
  const sill = options.opening?.sill ?? defaults.sill;
  const wallThickness = Math.max(0.03, Number(data.thickness || state.authoring.wallThickness) || 0.2);
  const objectDepth = openingObjectDepth(tool, wallThickness);
  const point = placement.point || pointAlongWallData(data, placement.offset ?? 0, true);
  const floorElevation = openingFloorElevationForWall(options.wall || placement.wall || data, point, options.opening);
  if (options.opening && !Number.isFinite(Number(options.opening.floorElevation))) options.opening.floorElevation = floorElevation;

  const object = options.preview
    ? createOpeningPreviewObject(tool, width, height, wallThickness, objectDepth)
    : new THREE.Mesh(createOpeningObjectGeometry(tool, width, height, objectDepth), createOpeningMaterials(tool));
  if (!object) return null;

  object.position.set(point.x, floorElevation + sill + height * 0.5, point.z);
  const dir = placement.dir || wallDirection(data);
  object.rotation.y = rotationYForWallDirection(dir);
  object.name = options.preview
    ? `${openingToolLabel(tool)} preview`
    : `${openingToolLabel(tool)}_${String(++state.authoring[tool === "window" ? "windowCount" : "doorCount"]).padStart(3, "0")}`;
  object.castShadow = false;
  object.receiveShadow = false;
  object.userData.authoringType = tool;
  object.userData.ifcHint = tool === "window" ? "IfcWindow" : "IfcDoor";
  object.userData.storeyId = placement.wall?.userData?.storeyId || getActiveStorey().id;
  object.userData.storeyName = placement.wall?.userData?.storeyName || getActiveStorey().name;
  object.userData.storeyElevation = Number(data.baseElevation ?? getActiveStoreyElevation());
  object.userData.floorElevation = floorElevation;
  object.userData.dimensions = { width, height, sill, wallThickness, objectDepth, floorElevation };
  if (!options.preview) {
    object.userData.opening = {
      id: options.opening?.id || null,
      wallId: placement.wall?.userData?.__modelerId || options.wall?.userData?.__modelerId || null,
      offset: placement.offset,
      type: tool,
    };
  }
  if (state.xray.active && !options.preview) applyXrayToMesh(object);
  return object;
}

function createOpeningMaterials(tool) {
  const assetKey = tool === "window" ? "window" : "door";
  const fallback = tool === "window" ? authoringWindowObjectMaterial : authoringDoorObjectMaterial;
  const assetMaterial = state.assets?.openings?.[assetKey]?.material;
  if (assetMaterial) {
    const material = assetMaterial.clone();
    material.side = THREE.FrontSide;
    material.transparent = false;
    material.depthWrite = true;
    return material;
  }

  return fallback.clone();
}

function openingObjectDepth(tool, wallThickness) {
  const t = Math.max(0.03, Number(wallThickness) || 0.2);
  // The wall opening is cut through the whole wall by the wall mesh generator,
  // but the visible joinery object must stay thinner than the host wall.
  // Keep stable architectural proportions instead of scaling the asset to 100%
  // of the wall thickness.
  if (tool === "window") return THREE.MathUtils.clamp(t * 0.45, 0.045, 0.12);
  return THREE.MathUtils.clamp(t * 0.38, 0.04, 0.10);
}

function createOpeningPreviewObject(tool, width, height, wallThickness, objectDepth) {
  // Preview has two layers:
  // 1. a through-wall cut volume / outline, so the future boolean is visible;
  // 2. the real joinery asset depth, so the user sees the thinner door/window object.
  // This keeps the depth-ratio fix while restoring a clear placement preview.
  const group = new THREE.Group();
  group.userData.__modelerOverlay = true;

  const cutDepth = Math.max(0.04, Number(wallThickness) || 0.2) + 0.026;
  const cutGeometry = createOpeningPreviewGeometry(tool, width, height, cutDepth);
  const cutMaterial = authoringOpeningPreviewMaterial.clone();
  cutMaterial.color.set(tool === "window" ? 0x7fd6ff : 0xffb15f);
  const cutMesh = new THREE.Mesh(cutGeometry, cutMaterial);
  cutMesh.name = `${openingToolLabel(tool)} cut preview`;
  cutMesh.renderOrder = 35;
  cutMesh.userData.__modelerOverlay = true;
  group.add(cutMesh);

  const objectGeometry = createOpeningObjectGeometry(tool, width, height, objectDepth);
  const objectMaterial = authoringPreviewMaterial.clone();
  objectMaterial.color.set(tool === "window" ? 0xbbeaff : 0xffd0a0);
  objectMaterial.opacity = 0.62;
  const objectMesh = new THREE.Mesh(objectGeometry, objectMaterial);
  objectMesh.name = `${openingToolLabel(tool)} object preview`;
  objectMesh.renderOrder = 36;
  objectMesh.userData.__modelerOverlay = true;
  group.add(objectMesh);

  const edgeGeometry = new THREE.EdgesGeometry(cutGeometry.clone());
  const edgeMaterial = authoringOpeningPreviewLineMaterial.clone();
  edgeMaterial.color.set(tool === "window" ? 0x5bc9ff : 0xff9248);
  const edges = new THREE.LineSegments(edgeGeometry, edgeMaterial);
  edges.name = `${openingToolLabel(tool)} outline preview`;
  edges.renderOrder = 37;
  edges.userData.__modelerOverlay = true;
  group.add(edges);

  return group;
}

function createOpeningPreviewGeometry(tool, width, height, depth) {
  const geometry = new THREE.BoxGeometry(
    Math.max(0.02, Number(width) || openingDefaults(tool).width),
    Math.max(0.02, Number(height) || openingDefaults(tool).height),
    Math.max(0.02, Number(depth) || 0.06),
  );
  geometry.computeBoundingBox();
  geometry.computeBoundingSphere();
  return geometry;
}

function createOpeningObjectGeometry(tool, width, height, objectDepth) {
  if (tool === "window") return createWindowMonolithGeometry(width, height, objectDepth);
  return createDoorMonolithGeometry(width, height, objectDepth);
}

function createOpeningAssetGeometry(asset, width, height, thickness) {
  if (!asset?.geometry || !asset?.baseSize) return null;
  const geometry = asset.geometry.clone();
  const sx = Math.max(0.001, width) / Math.max(0.001, asset.baseSize.x);
  const sy = Math.max(0.001, height) / Math.max(0.001, asset.baseSize.y);
  const sz = Math.max(0.001, thickness) / Math.max(0.001, asset.baseSize.z);
  geometry.scale(sx, sy, sz);
  geometry.computeVertexNormals();
  geometry.computeBoundingBox();
  geometry.computeBoundingSphere();
  return geometry;
}

function createDoorMonolithGeometry(width, height, thickness) {
  const assetGeometry = createOpeningAssetGeometry(state.assets?.openings?.door, width, height, thickness);
  if (assetGeometry) return assetGeometry;

  // Fallback if the custom GLB asset has not loaded yet.
  // A semantic door should be one selectable/exportable mesh. Keep the geometry
  // deliberately simple and monolithic so the GLB -> IFC classifier sees one
  // Door_* object instead of a decorative assembly of leaf/frame/handle parts.
  const panelWidth = Math.max(0.08, width * 0.92);
  const panelHeight = Math.max(0.08, height * 0.96);
  const panelDepth = Math.max(0.018, Math.min(thickness * 0.18, 0.08));
  const geometry = new THREE.BoxGeometry(panelWidth, panelHeight, panelDepth);
  geometry.computeBoundingBox();
  geometry.computeBoundingSphere();
  return geometry;
}

function createWindowMonolithGeometry(width, height, thickness) {
  const assetGeometry = createOpeningAssetGeometry(state.assets?.openings?.window, width, height, thickness);
  if (assetGeometry) return assetGeometry;

  // Fallback if the custom GLB asset has not loaded yet. One continuous
  // extruded ring, not a multi-part object: still one semantic IfcWindow mesh.
  const frame = THREE.MathUtils.clamp(Math.min(width, height) * 0.11, 0.045, 0.14);
  const outerW = Math.max(0.08, width * 0.94);
  const outerH = Math.max(0.08, height * 0.94);
  const innerW = Math.max(0.02, outerW - frame * 2);
  const innerH = Math.max(0.02, outerH - frame * 2);
  const depth = Math.max(0.018, Math.min(thickness * 0.16, 0.07));

  const shape = new THREE.Shape();
  shape.moveTo(-outerW * 0.5, -outerH * 0.5);
  shape.lineTo( outerW * 0.5, -outerH * 0.5);
  shape.lineTo( outerW * 0.5,  outerH * 0.5);
  shape.lineTo(-outerW * 0.5,  outerH * 0.5);
  shape.lineTo(-outerW * 0.5, -outerH * 0.5);

  const hole = new THREE.Path();
  hole.moveTo(-innerW * 0.5, -innerH * 0.5);
  hole.lineTo(-innerW * 0.5,  innerH * 0.5);
  hole.lineTo( innerW * 0.5,  innerH * 0.5);
  hole.lineTo( innerW * 0.5, -innerH * 0.5);
  hole.lineTo(-innerW * 0.5, -innerH * 0.5);
  shape.holes.push(hole);

  const geometry = new THREE.ExtrudeGeometry(shape, {
    depth,
    bevelEnabled: false,
    steps: 1,
  });
  geometry.translate(0, 0, -depth * 0.5);
  geometry.computeVertexNormals();
  geometry.computeBoundingBox();
  geometry.computeBoundingSphere();
  return geometry;
}

function openingDefaults(tool) {
  if (tool === "window") {
    return {
      width: Math.max(0.1, Number(state.authoring.windowWidth) || 1.2),
      height: Math.max(0.1, Number(state.authoring.windowHeight) || 1.2),
      sill: Math.max(0, Number(state.authoring.windowSill) || 0.9),
    };
  }
  return {
    width: Math.max(0.1, Number(state.authoring.doorWidth) || 0.9),
    height: Math.max(0.1, Number(state.authoring.doorHeight) || 2.1),
    sill: 0,
  };
}

function openingToolLabel(tool) {
  return tool === "window" ? "Window" : "Door";
}

function openingFloorElevationForWall(wallOrData, point = null, opening = null) {
  const data = wallOrData?.userData?.wallPath || wallOrData;
  const fallback = Number(data?.baseElevation ?? wallOrData?.userData?.storeyElevation ?? getActiveStoreyElevation());
  const stored = Number(opening?.floorElevation);
  if (Number.isFinite(stored)) return stored;
  return slabTopElevationAtPoint(point, wallOrData?.userData?.storeyId || data?.storeyId, fallback);
}

function slabTopElevationAtPoint(point, storeyId = null, fallbackElevation = 0) {
  if (!point || !state.modelRoot) return fallbackElevation;
  let best = null;
  const tolerance = Math.max(0.05, (Number(state.authoring.wallThickness) || 0.2) * 1.35);

  state.modelRoot.traverse((mesh) => {
    if (!mesh?.isMesh || mesh.userData?.authoringType !== "slab") return;
    if (storeyId && mesh.userData?.storeyId && mesh.userData.storeyId !== storeyId) return;
    const boundary = mesh.userData?.slabBoundary;
    if (!slabBoundaryContainsPoint(boundary, point, tolerance)) return;
    const slabBase = Number(boundary?.elevation ?? mesh.userData?.storeyElevation ?? fallbackElevation);
    const slabThickness = Math.max(0, Number(mesh.userData?.dimensions?.thickness) || Number(state.authoring.slabThickness) || 0.12);
    const top = slabBase + slabThickness;
    best = best == null ? top : Math.max(best, top);
  });

  return best == null ? fallbackElevation : best;
}

function slabBoundaryContainsPoint(boundary, point, tolerance = 0.02) {
  if (!boundary || !point) return false;
  const minX = Math.min(Number(boundary.minX), Number(boundary.maxX));
  const maxX = Math.max(Number(boundary.minX), Number(boundary.maxX));
  const minZ = Math.min(Number(boundary.minZ), Number(boundary.maxZ));
  const maxZ = Math.max(Number(boundary.minZ), Number(boundary.maxZ));
  if (![minX, maxX, minZ, maxZ].every(Number.isFinite)) return false;
  return point.x >= minX - tolerance
    && point.x <= maxX + tolerance
    && point.z >= minZ - tolerance
    && point.z <= maxZ + tolerance;
}

function cloneOpening(opening) {
  return opening ? { ...opening } : null;
}

function removeOpeningFromWall(wall, openingId) {
  const openings = wall?.userData?.wallPath?.openings;
  if (!Array.isArray(openings)) return null;
  const index = openings.findIndex((opening) => opening.id === openingId);
  if (index < 0) return null;
  const [removed] = openings.splice(index, 1);
  refreshWallMeshGeometry(wall);
  return removed || null;
}

function addOpeningToWall(wall, opening) {
  if (!wall?.userData?.wallPath || !opening) return;
  const openings = wall.userData.wallPath.openings = Array.isArray(wall.userData.wallPath.openings) ? wall.userData.wallPath.openings : [];
  if (!openings.some((item) => item.id === opening.id)) openings.push(cloneOpening(opening));
  refreshWallMeshGeometry(wall);
}

function wallDirection(wallData) {
  const length = Math.hypot(wallData.end.x - wallData.start.x, wallData.end.z - wallData.start.z) || 1;
  return new THREE.Vector3((wallData.end.x - wallData.start.x) / length, 0, (wallData.end.z - wallData.start.z) / length);
}

function pointAlongWallData(wallData, offset, centered = false) {
  const dir = wallDirection(wallData);
  const base = new THREE.Vector3(wallData.start.x + dir.x * offset, Number(wallData.baseElevation ?? getActiveStoreyElevation()), wallData.start.z + dir.z * offset);
  if (!centered) return base;
  const normal2 = new THREE.Vector2(-dir.z, dir.x);
  const centerOffset = wallCenterOffset(wallData.thickness, wallData.alignment || "center");
  return new THREE.Vector3(base.x + normal2.x * centerOffset, base.y, base.z + normal2.y * centerOffset);
}

function wallCenterOffset(thickness, alignment = "center") {
  const offsets = wallAlignmentOffsets(thickness, alignment);
  return (offsets.left + offsets.right) * 0.5;
}

function rotationYForWallDirection(dir) {
  return Math.atan2(-dir.z, dir.x);
}

function commitAuthoringPrimitive() {
  const start = state.authoring.drawStart;
  const end = state.authoring.drawCurrent;
  const createdTool = state.authoring.tool;
  if (!start || !end) return;

  const horizontalDistance = Math.hypot(end.x - start.x, end.z - start.z);
  const minSize = Math.max(0.02, state.authoring.gridStep * 0.25);
  if (horizontalDistance < minSize) {
    setStatus("Segment trop court : choisis un second point plus éloigné.", "warning");
    return;
  }

  const isWallLikeTool = createdTool === "wall" || createdTool === "partition";
  const previousWall = isWallLikeTool ? state.authoring.wallChainLastMesh : null;
  const prevPoint = previousWall?.userData?.wallPath?.start || null;
  const mesh = isWallLikeTool
    ? createWallMesh(start, end, {
        prevPoint,
        alignment: createdTool === "partition" ? "center" : state.authoring.wallAlignment,
        kind: createdTool === "partition" ? "partition" : "wall",
      })
    : createdTool === "stair"
      ? createStairMesh(start, end)
      : createSlabMesh(start, end);
  if (!mesh) {
    setStatus("Géométrie trop petite pour être créée.", "warning");
    return;
  }

  removeAuthoringPreview();
  const root = ensureAuthoringRoot();
  root.add(mesh);
  mesh.updateMatrixWorld(true);
  indexMeshes(root);
  const indexed = state.meshes.find((candidate) => candidate.uuid === mesh.uuid) || mesh;
  pushHistory({
    type: "createMesh",
    label: `Create ${authoringToolLabel(createdTool)}`,
    mesh: indexed,
    parent: root,
    meshId: indexed.userData.__modelerId,
  });
  if (isWallLikeTool && previousWall?.userData?.wallPath) {
    previousWall.userData.wallPath.next = end.clone();
    refreshWallMeshGeometry(previousWall);
  }
  if (isWallLikeTool) refreshAuthoredWallMiters();

  selectMesh(indexed);
  markDirty();

  if (isWallLikeTool) {
    state.authoring.wallChainLastMesh = indexed;
    state.authoring.drawStart = end.clone();
    state.authoring.drawCurrent = end.clone();
    removeAuthoringPreview();
    updateToolbarState();
    const detail = createdTool === "partition" ? "cloison intérieure" : wallAlignmentLabel();
    setStatus(`${authoringToolLabel(createdTool)} créé · ${escapeHtml(indexed.name)} · ${detail} · Shift guide 0°/45°/90° · clique le point suivant ou Stop/Échap.`, "ok");
    return;
  }

  state.authoring.drawStart = null;
  state.authoring.drawCurrent = null;
  setAuthoringTool("select", { silent: true });
  setStatus(`${authoringToolLabel(createdTool)} créé · ${escapeHtml(indexed.name)} · outil Select actif.`, "ok");
}

function createWallMesh(start, end, options = {}) {
  const length = Math.hypot(end.x - start.x, end.z - start.z);
  if (length < 1e-5) return null;

  const kind = options.kind || "wall";
  const height = kind === "partition"
    ? Math.max(0.05, Number(options.height ?? state.authoring.partitionHeight) || 3)
    : Math.max(0.05, Number(options.height ?? state.authoring.wallHeight) || 3);
  const thickness = kind === "partition"
    ? Math.max(0.01, Number(options.thickness ?? state.authoring.partitionThickness) || 0.075)
    : Math.max(0.01, Number(options.thickness ?? state.authoring.wallThickness) || 0.2);
  const baseElevation = getActiveStoreyElevation();
  const storey = getActiveStorey();
  const material = options.preview ? authoringPreviewMaterial.clone() : (kind === "partition" ? authoringPartitionMaterial.clone() : authoringWallMaterial.clone());
  const wallData = {
    start: start.clone(),
    end: end.clone(),
    prev: options.prevPoint?.clone?.() || null,
    next: options.nextPoint?.clone?.() || null,
    height,
    thickness,
    alignment: kind === "partition" ? "center" : (options.alignment || state.authoring.wallAlignment || "center"),
    kind,
    baseElevation,
    storeyId: storey.id,
    storeyName: storey.name,
    openings: Array.isArray(options.openings) ? options.openings.map(cloneOpening).filter(Boolean) : [],
  };
  const origin = wallGeometryOrigin(wallData);
  const geometry = createMiteredWallGeometry(wallData, origin);
  if (!geometry) return null;

  const mesh = new THREE.Mesh(geometry, material);
  mesh.position.set(origin.x, baseElevation, origin.z);
  mesh.name = options.preview ? (kind === "partition" ? "Cloison preview" : "Wall preview") : kind === "partition" ? `Cloison_${String(++state.authoring.partitionCount).padStart(3, "0")}` : `Wall_${String(++state.authoring.wallCount).padStart(3, "0")}`;
  mesh.castShadow = false;
  mesh.receiveShadow = false;
  mesh.userData.authoringType = "wall";
  mesh.userData.ifcHint = "IfcWall";
  mesh.userData.smeltIfcType = "IfcWall";
  mesh.userData.smeltPredefinedType = kind === "partition" ? ".PARTITIONING." : ".STANDARD.";
  mesh.userData.storeyId = storey.id;
  mesh.userData.storeyName = storey.name;
  mesh.userData.storeyElevation = baseElevation;
  mesh.userData.dimensions = { length, height, thickness, alignment: wallData.alignment, kind };
  mesh.userData.wallPath = wallData;
  return mesh;
}

function refreshWallMeshGeometry(mesh) {
  if (!mesh?.userData?.wallPath) return;
  const data = mesh.userData.wallPath;
  const origin = wallGeometryOrigin(data);
  const geometry = createMiteredWallGeometry(data, origin);
  if (!geometry) return;
  mesh.geometry?.dispose?.();
  mesh.geometry = geometry;
  mesh.position.set(origin.x, Number(data.baseElevation ?? getActiveStoreyElevation()), origin.z);
  mesh.userData.dimensions = {
    length: Math.hypot(data.end.x - data.start.x, data.end.z - data.start.z),
    height: data.height,
    thickness: data.thickness,
    alignment: data.alignment || "center",
    kind: data.kind || "wall",
  };
  mesh.updateMatrixWorld(true);
}

function wallGeometryOrigin(wall) {
  const footprint = wallFootprintPoints(wall.start, wall.end, wall.prev, wall.next, Math.max(0.01, Number(wall.thickness) || 0.2), wall.alignment || "center");
  const center = footprint.reduce((acc, point) => {
    acc.x += point.x;
    acc.z += point.z;
    return acc;
  }, new THREE.Vector3());
  center.x /= Math.max(1, footprint.length);
  center.z /= Math.max(1, footprint.length);
  center.y = Number(wall.baseElevation ?? getActiveStoreyElevation());
  return center;
}

function createMiteredWallGeometry(wall, origin = null) {
  const start = wall.start;
  const end = wall.end;
  const height = Math.max(0.05, Number(wall.height) || 3);
  const thickness = Math.max(0.01, Number(wall.thickness) || 0.2);
  const length = Math.hypot(end.x - start.x, end.z - start.z);
  if (length < 1e-5) return null;

  const localOrigin = origin || wallGeometryOrigin(wall);
  const vertices = [];
  const indices = [];
  const openings = normalizedWallOpenings(wall, length, height);

  if (!openings.length) {
    appendWallPrism(vertices, indices, wall, 0, length, 0, height, localOrigin);
  } else {
    let cursor = 0;
    for (const opening of openings) {
      if (opening.start > cursor) appendWallPrism(vertices, indices, wall, cursor, opening.start, 0, height, localOrigin);
      if (opening.sill > 0.001) appendWallPrism(vertices, indices, wall, opening.start, opening.end, 0, opening.sill, localOrigin);
      if (opening.top < height - 0.001) appendWallPrism(vertices, indices, wall, opening.start, opening.end, opening.top, height, localOrigin);
      cursor = Math.max(cursor, opening.end);
    }
    if (cursor < length) appendWallPrism(vertices, indices, wall, cursor, length, 0, height, localOrigin);
  }

  if (!vertices.length || !indices.length) return null;
  const geometry = new THREE.BufferGeometry();
  geometry.setAttribute("position", new THREE.Float32BufferAttribute(vertices, 3));
  geometry.setIndex(indices);
  geometry.computeVertexNormals();
  geometry.computeBoundingBox();
  geometry.computeBoundingSphere();
  return geometry;
}

function normalizedWallOpenings(wall, length, wallHeight) {
  const margin = Math.max(0.02, Number(wall.thickness || state.authoring.wallThickness) * 0.2);
  const openings = (Array.isArray(wall.openings) ? wall.openings : [])
    .map((opening) => {
      const width = Math.max(0.05, Number(opening.width) || 0.9);
      const half = width * 0.5;
      const center = THREE.MathUtils.clamp(Number(opening.offset) || 0, margin + half, Math.max(margin + half, length - margin - half));
      const start = THREE.MathUtils.clamp(center - half, margin, length - margin);
      const end = THREE.MathUtils.clamp(center + half, margin, length - margin);
      const base = Number(wall.baseElevation ?? getActiveStoreyElevation());
      const point = pointAlongWallData(wall, center, true);
      const floorElevation = openingFloorElevationForWall(wall, point, opening);
      const rawSill = Math.max(0, Number(opening.sill) || 0);
      const sill = THREE.MathUtils.clamp(Math.max(0, floorElevation - base) + rawSill, 0, wallHeight - 0.02);
      const height = Math.max(0.05, Number(opening.height) || 2.1);
      const top = THREE.MathUtils.clamp(sill + height, sill + 0.02, wallHeight);
      if (end - start < 0.05 || top - sill < 0.05) return null;
      return { ...opening, start, end, sill, top, width: end - start, height: top - sill };
    })
    .filter(Boolean)
    .sort((a, b) => a.start - b.start);

  // Merge only the horizontal blocking interval conservatively. We keep the
  // original openings if they don't overlap; overlapping openings become one
  // larger void, which is safer than generating tiny slivers of wall.
  const merged = [];
  for (const opening of openings) {
    const prev = merged[merged.length - 1];
    if (prev && opening.start <= prev.end + 0.01) {
      prev.end = Math.max(prev.end, opening.end);
      prev.sill = Math.min(prev.sill, opening.sill);
      prev.top = Math.max(prev.top, opening.top);
      prev.width = prev.end - prev.start;
      prev.height = prev.top - prev.sill;
    } else {
      merged.push({ ...opening });
    }
  }
  return merged;
}

function appendWallPrism(vertices, indices, wall, d0, d1, y0, y1, localOrigin) {
  const length = Math.hypot(wall.end.x - wall.start.x, wall.end.z - wall.start.z);
  if (d1 - d0 < 1e-5 || y1 - y0 < 1e-5 || length < 1e-5) return;
  const dir = new THREE.Vector3((wall.end.x - wall.start.x) / length, 0, (wall.end.z - wall.start.z) / length);
  const start = new THREE.Vector3(wall.start.x + dir.x * d0, wall.start.y, wall.start.z + dir.z * d0);
  const end = new THREE.Vector3(wall.start.x + dir.x * d1, wall.start.y, wall.start.z + dir.z * d1);
  const prev = d0 <= 1e-6 ? wall.prev : null;
  const next = d1 >= length - 1e-6 ? wall.next : null;
  const footprint = wallFootprintPoints(start, end, prev, next, wall.thickness, wall.alignment || "center");
  const base = vertices.length / 3;

  for (const point of footprint) vertices.push(point.x - localOrigin.x, y0, point.z - localOrigin.z);
  for (const point of footprint) vertices.push(point.x - localOrigin.x, y1, point.z - localOrigin.z);

  indices.push(base + 0, base + 2, base + 1, base + 0, base + 3, base + 2);
  indices.push(base + 4, base + 5, base + 6, base + 4, base + 6, base + 7);

  for (let i = 0; i < 4; i++) {
    const j = (i + 1) % 4;
    indices.push(base + i, base + j, base + j + 4, base + i, base + j + 4, base + i + 4);
  }
}

function wallFootprintPoints(start, end, prevPoint, nextPoint, thickness, alignment = "center") {
  const dir = new THREE.Vector2(end.x - start.x, end.z - start.z).normalize();
  const normal = new THREE.Vector2(-dir.y, dir.x);
  const offsets = wallAlignmentOffsets(thickness, alignment);
  const clearance = wallJointClearance(thickness);
  const effectiveStart = prevPoint
    ? new THREE.Vector3(start.x + dir.x * clearance, start.y, start.z + dir.y * clearance)
    : start;
  const effectiveEnd = nextPoint
    ? new THREE.Vector3(end.x - dir.x * clearance, end.y, end.z - dir.y * clearance)
    : end;

  const leftStart = wallMiterPoint(effectiveStart, dir, normal, offsets.left, prevPoint, "start", thickness);
  const leftEnd = wallMiterPoint(effectiveEnd, dir, normal, offsets.left, nextPoint, "end", thickness);
  const rightEnd = wallMiterPoint(effectiveEnd, dir, normal, offsets.right, nextPoint, "end", thickness);
  const rightStart = wallMiterPoint(effectiveStart, dir, normal, offsets.right, prevPoint, "start", thickness);

  return [leftStart, leftEnd, rightEnd, rightStart];
}

function wallJointClearance(thickness) {
  // A tiny gap avoids physical overlaps / coplanar collision reports between
  // separate wall meshes when they meet at a corner. It is intentionally far
  // below normal drafting precision, so the viewport still reads as a clean
  // joined wall while IFC collision checks don't see interpenetrating solids.
  return Math.min(0.004, Math.max(0.0008, Math.max(0.01, Number(thickness) || 0.2) * 0.01));
}

function wallAlignmentOffsets(thickness, alignment = "center") {
  const t = Math.max(0.01, Number(thickness) || 0.2);
  if (alignment === "left") return { left: t, right: 0 };
  if (alignment === "right") return { left: 0, right: -t };
  return { left: t * 0.5, right: -t * 0.5 };
}

function wallMiterPoint(vertex, dir, normal, offset, neighborPoint, side, thickness) {
  const fallback = new THREE.Vector3(vertex.x + normal.x * offset, vertex.y, vertex.z + normal.y * offset);
  if (!neighborPoint) return fallback;

  const neighborDir = side === "start"
    ? new THREE.Vector2(vertex.x - neighborPoint.x, vertex.z - neighborPoint.z)
    : new THREE.Vector2(neighborPoint.x - vertex.x, neighborPoint.z - vertex.z);
  if (neighborDir.lengthSq() < 1e-10) return fallback;
  neighborDir.normalize();

  const neighborNormal = new THREE.Vector2(-neighborDir.y, neighborDir.x);
  const currentPoint = new THREE.Vector2(vertex.x + normal.x * offset, vertex.z + normal.y * offset);
  const neighborOffsetPoint = new THREE.Vector2(vertex.x + neighborNormal.x * offset, vertex.z + neighborNormal.y * offset);
  const intersection = lineIntersection2D(currentPoint, dir, neighborOffsetPoint, neighborDir);
  if (!intersection) return fallback;

  // Avoid long spikes on very acute angles. Falling back to a square cap is less
  // elegant but much more predictable for quick plan tracing.
  const miterLength = Math.hypot(intersection.x - vertex.x, intersection.y - vertex.z);
  const maxMiter = Math.max(Math.abs(offset), Math.max(0.01, thickness) * 0.5) * 6;
  if (!Number.isFinite(miterLength) || miterLength > maxMiter) return fallback;
  return new THREE.Vector3(intersection.x, vertex.y, intersection.y);
}

function lineIntersection2D(p, r, q, s) {
  const cross = r.x * s.y - r.y * s.x;
  if (Math.abs(cross) < 1e-8) return null;
  const qmpx = q.x - p.x;
  const qmpy = q.y - p.y;
  const t = (qmpx * s.y - qmpy * s.x) / cross;
  return new THREE.Vector2(p.x + r.x * t, p.y + r.y * t);
}

function createWallsFromSelectedSlabBoundary() {
  const slab = state.selected;
  if (!slab || slab.userData?.authoringType !== "slab") {
    setStatus("Sélectionne une slab, puis clique Walls from slab pour générer des murs propres sur son contour.", "warning");
    return;
  }

  ensureAuthoringRoot();
  cancelAuthoringDraw();
  if (slab.userData?.storeyId && slab.userData.storeyId !== state.authoring.activeStoreyId) {
    setActiveStorey(slab.userData.storeyId, { silent: true });
  }

  const points = slabBoundaryPoints(slab);
  if (!points?.length) {
    setStatus("Impossible de lire le contour de cette slab.", "warning");
    return;
  }

  const root = ensureAuthoringRoot();
  const created = [];
  for (let i = 0; i < points.length; i++) {
    const prev = points[(i - 1 + points.length) % points.length];
    const start = points[i];
    const end = points[(i + 1) % points.length];
    const next = points[(i + 2) % points.length];
    const mesh = createWallMesh(start, end, { prevPoint: prev, nextPoint: next, alignment: "left", kind: "wall" });
    if (!mesh) continue;
    mesh.userData.wallPath.prev = prev.clone();
    mesh.userData.wallPath.next = next.clone();
    root.add(mesh);
    created.push(mesh);
  }

  if (!created.length) {
    setStatus("Aucun mur créé : slab trop petite ou contour invalide.", "warning");
    return;
  }

  indexMeshes(root);
  refreshAuthoredWallMiters();
  const indexed = created.map((mesh) => state.meshes.find((candidate) => candidate.uuid === mesh.uuid) || mesh);
  pushHistory({
    type: "createMeshes",
    label: `Create ${indexed.length} perimeter walls`,
    meshes: indexed,
    parent: root,
  });
  selectMesh(indexed[0] || null);
  markDirty();
  renderTree();
  renderProperties();
  updateUiEnabled();
  setStatus(`${indexed.length} murs créés sur le contour de ${escapeHtml(slab.name)} · alignement face intérieure.`, "ok");
}


function updateRoofSetting(key, value) {
  if (key === "roofType") {
    const allowed = ["flat", "shed", "gable"];
    state.authoring.roofType = allowed.includes(value) ? value : "gable";
  } else if (key === "roofRidgeDirection") {
    state.authoring.roofRidgeDirection = value === "z" ? "z" : "x";
  } else {
    const numeric = Number(value);
    const min = key === "roofPitch" || key === "roofOverhang" ? 0 : 0.01;
    if (!Number.isFinite(numeric) || numeric < min) return;
    if (key === "roofPitch") state.authoring.roofPitch = THREE.MathUtils.clamp(numeric, 0, 80);
    else state.authoring[key] = key === "stairSteps" ? Math.max(1, Math.round(numeric)) : numeric;
  }
  updateRoofPreviewFromSelection();
  markDirty();
  renderProperties();
  updateToolbarState();
}

function selectedRoofBaseSlab() {
  return state.selected?.userData?.authoringType === "slab" ? state.selected : null;
}

function updateRoofPreviewFromSelection() {
  if (state.authoring.tool !== "roof") return;
  removeAuthoringPreview();
  const slab = selectedRoofBaseSlab();
  if (!slab) return;
  const mesh = createRoofMeshFromSlab(slab, { preview: true });
  if (!mesh) return;
  mesh.userData.__modelerOverlay = true;
  mesh.name = "Roof preview";
  mesh.renderOrder = 25;
  state.authoring.preview = mesh;
  state.scene.add(mesh);
}

function createRoofFromSelectedSlab() {
  const slab = selectedRoofBaseSlab();
  if (!slab) {
    setStatus("Sélectionne une slab, puis clique Roof from slab pour générer une toiture.", "warning");
    return;
  }

  ensureAuthoringRoot();
  cancelAuthoringDraw();
  if (slab.userData?.storeyId && slab.userData.storeyId !== state.authoring.activeStoreyId) {
    setActiveStorey(slab.userData.storeyId, { silent: true });
  }

  const mesh = createRoofMeshFromSlab(slab);
  if (!mesh) {
    setStatus("Impossible de créer la toiture : contour de slab invalide.", "warning");
    return;
  }

  removeAuthoringPreview();
  const root = ensureAuthoringRoot();
  root.add(mesh);
  mesh.updateMatrixWorld(true);
  indexMeshes(root);
  const indexed = state.meshes.find((candidate) => candidate.uuid === mesh.uuid) || mesh;
  pushHistory({
    type: "createMesh",
    label: `Create ${roofTypeLabel(state.authoring.roofType)} roof`,
    mesh: indexed,
    parent: root,
    meshId: indexed.userData.__modelerId,
  });
  selectMesh(indexed);
  markDirty();
  renderTree();
  renderProperties();
  updateUiEnabled();
  setStatus(`${roofTypeLabel(indexed.userData?.roofData?.type)} créé depuis ${escapeHtml(slab.name || "Slab")} · mesh classifiable IfcRoof.`, "ok");
}

function roofTypeLabel(type = state.authoring.roofType) {
  if (type === "flat") return "Flat";
  if (type === "shed") return "Shed";
  return "Gable";
}

function createRoofMeshFromSlab(slab, options = {}) {
  const points = slabBoundaryPoints(slab);
  if (!points?.length) return null;
  const xs = points.map((p) => p.x);
  const zs = points.map((p) => p.z);
  const minX0 = Math.min(...xs);
  const maxX0 = Math.max(...xs);
  const minZ0 = Math.min(...zs);
  const maxZ0 = Math.max(...zs);
  const overhang = Math.max(0, Number(state.authoring.roofOverhang) || 0);
  const minX = minX0 - overhang;
  const maxX = maxX0 + overhang;
  const minZ = minZ0 - overhang;
  const maxZ = maxZ0 + overhang;
  const width = maxX - minX;
  const depth = maxZ - minZ;
  if (width < 0.05 || depth < 0.05) return null;

  const storey = getActiveStorey();
  const type = ["flat", "shed", "gable"].includes(state.authoring.roofType) ? state.authoring.roofType : "gable";
  const pitch = THREE.MathUtils.clamp(Number(state.authoring.roofPitch) || 0, 0, 80);
  const thickness = Math.max(0.03, Number(state.authoring.roofThickness) || 0.18);
  const eavesHeight = Math.max(0.05, Number(state.authoring.roofEavesHeight) || Number(storey?.height) || 3);
  const baseElevation = Number(slab.userData?.storeyElevation ?? getActiveStoreyElevation());
  const eavesY = baseElevation + eavesHeight;
  const ridgeDirection = state.authoring.roofRidgeDirection === "z" ? "z" : "x";
  const pitchRad = THREE.MathUtils.degToRad(pitch);

  const geometry = createRoofGeometry({ type, minX, maxX, minZ, maxZ, eavesY, thickness, pitchRad, ridgeDirection });
  if (!geometry) return null;
  geometry.computeBoundingBox();
  const localCenter = new THREE.Vector3();
  geometry.boundingBox?.getCenter(localCenter);
  geometry.translate(-localCenter.x, -localCenter.y, -localCenter.z);
  geometry.computeBoundingBox();
  geometry.computeBoundingSphere();
  const material = options.preview ? authoringPreviewMaterial.clone() : authoringRoofMaterial.clone();
  if (options.preview) material.opacity = 0.36;
  const mesh = new THREE.Mesh(geometry, material);
  mesh.position.copy(localCenter);
  mesh.name = options.preview ? "Roof preview" : `Roof_${roofTypeLabel(type)}_${String(++state.authoring.roofCount).padStart(3, "0")}`;
  mesh.castShadow = false;
  mesh.receiveShadow = false;
  mesh.userData.authoringType = "roof";
  mesh.userData.ifcHint = "IfcRoof";
  mesh.userData.storeyId = slab.userData?.storeyId || storey.id;
  mesh.userData.storeyName = slab.userData?.storeyName || storey.name;
  mesh.userData.storeyElevation = baseElevation;
  mesh.userData.dimensions = { width, depth, thickness, overhang, pitch, eavesHeight, ridgeDirection, type };
  mesh.userData.roofData = {
    type,
    minX,
    maxX,
    minZ,
    maxZ,
    eavesY,
    thickness,
    pitch,
    overhang,
    eavesHeight,
    ridgeDirection,
    storeyId: mesh.userData.storeyId,
    storeyName: mesh.userData.storeyName,
    storeyElevation: baseElevation,
    sourceSlabId: slab.userData?.__modelerId || null,
  };
  if (state.xray.active && !options.preview) applyXrayToMesh(mesh);
  return mesh;
}

function createRoofGeometry(data) {
  if (data.type === "flat") return createFlatRoofGeometry(data);
  if (data.type === "shed") return createShedRoofGeometry(data);
  return createGableRoofGeometry(data);
}

function createFlatRoofGeometry({ minX, maxX, minZ, maxZ, eavesY, thickness }) {
  const geometry = new THREE.BoxGeometry(maxX - minX, thickness, maxZ - minZ);
  geometry.translate((minX + maxX) * 0.5, eavesY + thickness * 0.5, (minZ + maxZ) * 0.5);
  geometry.computeBoundingBox();
  geometry.computeBoundingSphere();
  return geometry;
}

function createShedRoofGeometry({ minX, maxX, minZ, maxZ, eavesY, thickness, pitchRad, ridgeDirection }) {
  const vertices = [];
  const indices = [];
  const run = ridgeDirection === "z" ? (maxZ - minZ) : (maxX - minX);
  const rise = Math.tan(pitchRad) * Math.max(0, run);
  const topY = (x, z) => eavesY + (ridgeDirection === "z" ? ((z - minZ) / Math.max(1e-6, maxZ - minZ)) : ((x - minX) / Math.max(1e-6, maxX - minX))) * rise;
  const pts = [
    new THREE.Vector3(minX, 0, minZ),
    new THREE.Vector3(maxX, 0, minZ),
    new THREE.Vector3(maxX, 0, maxZ),
    new THREE.Vector3(minX, 0, maxZ),
  ];
  for (const p of pts) vertices.push(p.x, topY(p.x, p.z) - thickness, p.z);
  for (const p of pts) vertices.push(p.x, topY(p.x, p.z), p.z);
  addQuad(indices, 0, 3, 2, 1); // underside
  addQuad(indices, 4, 5, 6, 7); // top
  addQuad(indices, 0, 1, 5, 4);
  addQuad(indices, 1, 2, 6, 5);
  addQuad(indices, 2, 3, 7, 6);
  addQuad(indices, 3, 0, 4, 7);
  return roofBufferGeometry(vertices, indices);
}

function createGableRoofGeometry({ minX, maxX, minZ, maxZ, eavesY, thickness, pitchRad, ridgeDirection }) {
  const vertices = [];
  const indices = [];
  const alongX = ridgeDirection === "x";
  const run = alongX ? (maxZ - minZ) * 0.5 : (maxX - minX) * 0.5;
  const rise = Math.tan(pitchRad) * Math.max(0, run);
  const ridgeY = eavesY + rise;
  if (alongX) {
    const midZ = (minZ + maxZ) * 0.5;
    const pts = [
      [minX, eavesY - thickness, minZ], [minX, ridgeY - thickness, midZ], [minX, eavesY - thickness, maxZ],
      [minX, eavesY, minZ], [minX, ridgeY, midZ], [minX, eavesY, maxZ],
      [maxX, eavesY - thickness, minZ], [maxX, ridgeY - thickness, midZ], [maxX, eavesY - thickness, maxZ],
      [maxX, eavesY, minZ], [maxX, ridgeY, midZ], [maxX, eavesY, maxZ],
    ];
    for (const p of pts) vertices.push(...p);
    addQuad(indices, 3, 9, 10, 4);   // top slope A
    addQuad(indices, 4, 10, 11, 5);  // top slope B
    addQuad(indices, 0, 1, 7, 6);    // underside A
    addQuad(indices, 1, 2, 8, 7);    // underside B
    addQuad(indices, 0, 6, 9, 3);    // eave side
    addQuad(indices, 2, 5, 11, 8);   // eave side
    addRoofCap(indices, [0, 1, 2, 5, 4, 3]);
    addRoofCap(indices, [6, 9, 10, 7, 8, 11]);
  } else {
    const midX = (minX + maxX) * 0.5;
    const pts = [
      [minX, eavesY - thickness, minZ], [midX, ridgeY - thickness, minZ], [maxX, eavesY - thickness, minZ],
      [minX, eavesY, minZ], [midX, ridgeY, minZ], [maxX, eavesY, minZ],
      [minX, eavesY - thickness, maxZ], [midX, ridgeY - thickness, maxZ], [maxX, eavesY - thickness, maxZ],
      [minX, eavesY, maxZ], [midX, ridgeY, maxZ], [maxX, eavesY, maxZ],
    ];
    for (const p of pts) vertices.push(...p);
    addQuad(indices, 3, 4, 10, 9);   // top slope A
    addQuad(indices, 4, 5, 11, 10);  // top slope B
    addQuad(indices, 0, 6, 7, 1);    // underside A
    addQuad(indices, 1, 7, 8, 2);    // underside B
    addQuad(indices, 0, 3, 9, 6);    // eave side
    addQuad(indices, 2, 8, 11, 5);   // eave side
    addRoofCap(indices, [0, 1, 2, 5, 4, 3]);
    addRoofCap(indices, [6, 9, 10, 7, 8, 11]);
  }
  return roofBufferGeometry(vertices, indices);
}

function addQuad(indices, a, b, c, d) {
  indices.push(a, b, c, a, c, d);
}

function addRoofCap(indices, polygon) {
  for (let i = 1; i < polygon.length - 1; i++) indices.push(polygon[0], polygon[i], polygon[i + 1]);
}

function roofBufferGeometry(vertices, indices) {
  if (!vertices.length || !indices.length) return null;
  const geometry = new THREE.BufferGeometry();
  geometry.setAttribute("position", new THREE.Float32BufferAttribute(vertices, 3));
  geometry.setIndex(indices);
  geometry.computeVertexNormals();
  geometry.computeBoundingBox();
  geometry.computeBoundingSphere();
  return geometry;
}

function slabBoundaryPoints(slab) {
  const boundary = slab?.userData?.slabBoundary;
  const y = Number(slab?.userData?.storeyElevation ?? getActiveStoreyElevation());
  if (boundary && [boundary.minX, boundary.maxX, boundary.minZ, boundary.maxZ].every((value) => Number.isFinite(Number(value)))) {
    const minX = Number(boundary.minX);
    const maxX = Number(boundary.maxX);
    const minZ = Number(boundary.minZ);
    const maxZ = Number(boundary.maxZ);
    return [
      new THREE.Vector3(minX, y, minZ),
      new THREE.Vector3(maxX, y, minZ),
      new THREE.Vector3(maxX, y, maxZ),
      new THREE.Vector3(minX, y, maxZ),
    ];
  }

  slab.updateMatrixWorld(true);
  const box = new THREE.Box3().setFromObject(slab);
  if (box.isEmpty()) return null;
  return [
    new THREE.Vector3(box.min.x, y, box.min.z),
    new THREE.Vector3(box.max.x, y, box.min.z),
    new THREE.Vector3(box.max.x, y, box.max.z),
    new THREE.Vector3(box.min.x, y, box.max.z),
  ];
}

function slabVisualInset(width, depth) {
  const t = Math.max(0, Number(state.authoring.wallThickness) || 0.2);
  return Math.max(0, Math.min(t, width * 0.45, depth * 0.45));
}

function createStairMesh(start, end, options = {}) {
  const baseElevation = getActiveStoreyElevation();
  const totalRun = Math.hypot(end.x - start.x, end.z - start.z);
  const minRun = Math.max(0.25, Number(state.authoring.gridStep || 0.1) * 2);
  if (totalRun < minRun) return null;

  const width = Math.max(0.2, Number(options.width ?? state.authoring.stairWidth) || 0.9);
  const steps = Math.max(1, Math.round(Number(options.steps ?? state.authoring.stairSteps) || 12));
  const rise = Math.max(0.05, Number(options.rise ?? state.authoring.stairRise) || 0.17);
  const stepDepth = totalRun / steps;
  const height = steps * rise;
  const dir = new THREE.Vector3((end.x - start.x) / totalRun, 0, (end.z - start.z) / totalRun);
  const normal = new THREE.Vector3(-dir.z, 0, dir.x);
  const origin = new THREE.Vector3((start.x + end.x) * 0.5, baseElevation + height * 0.5, (start.z + end.z) * 0.5);

  const vertices = [];
  const indices = [];
  for (let i = 0; i < steps; i++) {
    const d0 = i * stepDepth;
    const d1 = (i + 1) * stepDepth;
    const y0 = baseElevation;
    const y1 = baseElevation + (i + 1) * rise;
    appendOrientedBox(vertices, indices, start, dir, normal, d0, d1, -width * 0.5, width * 0.5, y0, y1, origin);
  }

  const geometry = new THREE.BufferGeometry();
  geometry.setAttribute("position", new THREE.Float32BufferAttribute(vertices, 3));
  geometry.setIndex(indices);
  geometry.computeVertexNormals();
  geometry.computeBoundingBox();
  geometry.computeBoundingSphere();

  const material = options.preview ? authoringPreviewMaterial.clone() : authoringStairMaterial.clone();
  const mesh = new THREE.Mesh(geometry, material);
  mesh.position.copy(origin);
  mesh.castShadow = false;
  mesh.receiveShadow = false;
  mesh.name = options.preview ? "Escalier preview" : `Stair_${String(++state.authoring.stairCount).padStart(3, "0")}`;
  const storey = getActiveStorey();
  mesh.userData.authoringType = "stair";
  mesh.userData.ifcHint = "IfcStair";
  mesh.userData.smeltIfcType = "IfcStair";
  mesh.userData.storeyId = storey.id;
  mesh.userData.storeyName = storey.name;
  mesh.userData.storeyElevation = baseElevation;
  mesh.userData.dimensions = { width, steps, rise, run: totalRun, stepDepth, height };
  mesh.userData.stairData = {
    start: start.clone(),
    end: end.clone(),
    width,
    steps,
    rise,
    run: totalRun,
    baseElevation,
    storeyId: storey.id,
    storeyName: storey.name,
  };
  return mesh;
}

function appendOrientedBox(vertices, indices, originPoint, dir, normal, d0, d1, w0, w1, y0, y1, localOrigin) {
  const corners = [
    worldPointAlong(originPoint, dir, normal, d0, w0, y0),
    worldPointAlong(originPoint, dir, normal, d1, w0, y0),
    worldPointAlong(originPoint, dir, normal, d1, w1, y0),
    worldPointAlong(originPoint, dir, normal, d0, w1, y0),
    worldPointAlong(originPoint, dir, normal, d0, w0, y1),
    worldPointAlong(originPoint, dir, normal, d1, w0, y1),
    worldPointAlong(originPoint, dir, normal, d1, w1, y1),
    worldPointAlong(originPoint, dir, normal, d0, w1, y1),
  ];
  const base = vertices.length / 3;
  for (const point of corners) vertices.push(point.x - localOrigin.x, point.y - localOrigin.y, point.z - localOrigin.z);
  indices.push(
    base + 0, base + 2, base + 1, base + 0, base + 3, base + 2,
    base + 4, base + 5, base + 6, base + 4, base + 6, base + 7,
    base + 0, base + 1, base + 5, base + 0, base + 5, base + 4,
    base + 1, base + 2, base + 6, base + 1, base + 6, base + 5,
    base + 2, base + 3, base + 7, base + 2, base + 7, base + 6,
    base + 3, base + 0, base + 4, base + 3, base + 4, base + 7,
  );
}

function worldPointAlong(originPoint, dir, normal, d, w, y) {
  return new THREE.Vector3(
    originPoint.x + dir.x * d + normal.x * w,
    y,
    originPoint.z + dir.z * d + normal.z * w,
  );
}

function createSlabMesh(start, end, options = {}) {
  const width = Math.abs(end.x - start.x);
  const depth = Math.abs(end.z - start.z);
  const min = Math.max(0.02, state.authoring.gridStep * 0.1);
  if (width < min || depth < min) return null;

  const thickness = Math.max(0.01, Number(state.authoring.slabThickness) || 0.12);
  const baseElevation = getActiveStoreyElevation();
  const storey = getActiveStorey();
  const inset = options.preview ? 0 : slabVisualInset(width, depth);
  const visualWidth = Math.max(0.02, width - inset * 2);
  const visualDepth = Math.max(0.02, depth - inset * 2);
  const minX = Math.min(start.x, end.x);
  const maxX = Math.max(start.x, end.x);
  const minZ = Math.min(start.z, end.z);
  const maxZ = Math.max(start.z, end.z);
  const geometry = new THREE.BoxGeometry(visualWidth, thickness, visualDepth);
  const material = options.preview ? authoringPreviewMaterial.clone() : authoringSlabMaterial.clone();
  const mesh = new THREE.Mesh(geometry, material);
  mesh.position.set((start.x + end.x) * 0.5, baseElevation + thickness * 0.5, (start.z + end.z) * 0.5);
  mesh.name = options.preview ? "Slab preview" : `Slab_${String(++state.authoring.slabCount).padStart(3, "0")}`;
  mesh.castShadow = false;
  mesh.receiveShadow = false;
  mesh.userData.authoringType = "slab";
  mesh.userData.ifcHint = "IfcSlab";
  mesh.userData.storeyId = storey.id;
  mesh.userData.storeyName = storey.name;
  mesh.userData.storeyElevation = baseElevation;
  mesh.userData.dimensions = { width, depth, visualWidth, visualDepth, thickness, inset };
  mesh.userData.slabBoundary = { minX, maxX, minZ, maxZ, elevation: baseElevation };
  return mesh;
}

function formatNumber(value) {
  return Number(value || 0).toFixed(2).replace(/\.00$/, "");
}

function updateAuthoringSettingFromInput(key, value) {
  const numeric = Number(value);
  const min = key === "windowSill" ? 0 : 0.0001;
  if (!Number.isFinite(numeric) || numeric < min) return;
  state.authoring[key] = key === "stairSteps" ? Math.max(1, Math.round(numeric)) : numeric;
  markDirty();
  renderProperties();
}

async function loadFile(file, options = {}) {
  if (!/\.(glb|gltf)$/i.test(file.name)) {
    setStatus("Le modeler attend un fichier .glb ou .gltf.", "error");
    return;
  }

  if (!options.fromProject) {
    state.projectId = null;
    state.project = null;
    state.returnToViewer = false;
  }

  setStatus(`<span class="spinner"></span>Chargement de <strong>${escapeHtml(file.name)}</strong> (${formatBytes(file.size)})…`);
  clearScene({ silent: true });

  const url = URL.createObjectURL(file);
  state.objectUrls.add(url);

  try {
    const loader = createGLTFLoader();
    const gltf = await loader.loadAsync(url);
    const root = gltf.scene || gltf.scenes?.[0];
    if (!root) throw new Error("Le GLB ne contient pas de scène exploitable.");

    root.name = root.name || file.name.replace(/\.(glb|gltf)$/i, "");
    state.scene.add(root);
    state.modelRoot = root;
    state.currentFile = file;
    state.currentFileName = file.name;

    indexMeshes(root);
    if (state.meshes.length === 0) {
      setStatus("GLB chargé, mais aucun mesh éditable n’a été trouvé.", "warning");
    } else {
      setStatus(`GLB chargé : <strong>${state.meshes.length}</strong> mesh${state.meshes.length > 1 ? "es" : ""} éditable${state.meshes.length > 1 ? "s" : ""}.`, "ok");
    }

    renderTree();
    renderProperties();
    updateUiEnabled();
    fitCameraToObject(root);
  } catch (error) {
    console.error(error);
    setStatus(`Erreur de chargement GLB : ${escapeHtml(error.message)}`, "error");
    clearScene({ silent: true });
  } finally {
    URL.revokeObjectURL(url);
    state.objectUrls.delete(url);
    input.value = "";
  }
}

async function loadProjectFromUrl() {
  const params = new URLSearchParams(window.location.search);
  const projectId = params.get("project");
  if (!projectId) return;

  const project = await getProject(projectId);
  if (!project?.glbBlob) {
    throw new Error("Projet local introuvable ou GLB source absent.");
  }

  state.projectId = project.id;
  state.project = project;
  state.returnToViewer = params.get("return") === "viewer";
  setLastProjectId(project.id);

  const file = blobToGlbFile(project.glbBlob, project.glbFileName || "model.glb");
  await loadFile(file, { fromProject: true });

  const repairCount = repairAuthoringRoundTripGeometry();
  if (repairCount > 0) {
    renderTree();
    renderProperties();
    updateUiEnabled();
    setStatus(`GLB source ouvert depuis le viewer · ${repairCount} ouverture(s) / mur(s) relinké(s) au GLB source.`, "ok");
  }

  // The IFC space overlay is useful for debugging IFC generation, but it is very
  // intrusive when the user simply wants to edit the source geometry again: it
  // can cover the model with a large transparent blue volume and make selected
  // doors/windows look as if they moved to the middle of the room. Keep it opt-in.
  const showIfcSpaces = params.get("ifcSpaces") === "1" || params.get("showIfcSpaces") === "1";
  const overlayCount = showIfcSpaces ? addGeneratedIfcSpacesFromProject(project.ifcText) : 0;
  if (overlayCount > 0) {
    indexMeshes(state.modelRoot);
    renderTree();
    renderProperties();
    updateUiEnabled();
    setStatus(`GLB source ouvert depuis le viewer · ${overlayCount} space(s) IFC généré(s) ajouté(s) comme overlays de debug.`, "ok");
  }

  if (state.returnToViewer && convertIfcButton) {
    convertIfcButton.textContent = "Enregistrer → retour viewer IFC";
  }

  const pending = Number(project.edits?.length || 0);
  if (pending > 0) {
    const overlaySuffix = state.ifcOverlayCount > 0 ? ` · ${state.ifcOverlayCount} space(s) IFC éditable(s)` : "";
    setStatus("GLB source ouvert depuis le viewer · " + pending + " reclassification(s) seront réappliquée(s) au retour" + overlaySuffix + ".", "ok");
  }
}

async function reexportIfcWithProjectEdits(ifcText, fileName) {
  const edits = state.project?.edits || [];
  if (!edits.length) return { ifcText, applied: 0, errors: 0 };

  const response = await fetch("/api/reexport", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ ifcText, edits, fileName }),
  });

  if (!response.ok) {
    const err = await response.json().catch(() => ({ error: "Erreur serveur reexport" }));
    throw new Error(err.error || `HTTP ${response.status}`);
  }

  return {
    ifcText: await response.text(),
    applied: Number(response.headers.get("X-Edits-Applied") || 0),
    errors: Number(response.headers.get("X-Edits-Errors") || 0),
  };
}

async function persistConvertedProject(glbBlob, ifcText, ifcFileName, options = {}) {
  const patch = {
    glbBlob,
    glbFileName: editedFileName("glb"),
    ifcText,
    ifcFileName: safeFileName(ifcFileName, "model.ifc"),
    edits: [],
    lastOpenedIn: "modeler",
    source: state.project?.source || (state.currentFile ? "modeler-upload" : "modeler-from-scratch"),
  };

  const updated = state.projectId
    ? await updateProject(state.projectId, patch)
    : await saveProject({
      id: makeProjectId(),
      ...patch,
      createdFrom: "modeler",
    });

  state.projectId = updated.id;
  state.project = updated;
  setLastProjectId(updated.id);

  if (options.returnToViewer) {
    window.location.href = `/viewer.html?project=${encodeURIComponent(updated.id)}&from=modeler`;
  }

  return updated;
}

async function saveRoundTripAndReturn(glbBlob, ifcText, ifcFileName) {
  await persistConvertedProject(glbBlob, ifcText, ifcFileName, { returnToViewer: true });
}

async function preloadOpeningAssets() {
  const entries = Object.entries(state.assets?.openings || {});
  if (!entries.length) return;

  const loader = createGLTFLoader();
  await Promise.all(entries.map(async ([key, asset]) => {
    if (!asset || asset.loaded || asset.error) return;

    try {
      const gltf = await loader.loadAsync(asset.url);
      const root = gltf.scene || gltf.scenes?.[0];
      const extracted = extractFirstMeshGeometryAndMaterial(root);
      if (!extracted?.geometry) throw new Error("asset GLB sans mesh exploitable");

      asset.geometry = normalizeOpeningAssetGeometry(extracted.geometry);
      asset.material = extracted.material || (key === "window" ? authoringWindowObjectMaterial.clone() : authoringDoorObjectMaterial.clone());
      asset.baseSize = asset.geometry.userData?.openingAssetBaseSize || (key === "window" ? new THREE.Vector3(1.2, 1.2, 0.08) : new THREE.Vector3(0.9, 2.1, 0.1));
      asset.loaded = true;

      console.info(`[modeler] ${asset.label || key} asset loaded: ${asset.url}`, asset.baseSize);
    } catch (error) {
      asset.error = error;
      console.warn(`[modeler] ${asset?.label || key} asset fallback: ${asset?.url}`, error);
    }
  }));
}

function extractFirstMeshGeometryAndMaterial(root) {
  if (!root) return null;
  root.updateMatrixWorld(true);

  let result = null;
  root.traverse((object) => {
    if (result || !object.isMesh || !object.geometry) return;
    const geometry = object.geometry.clone();
    geometry.applyMatrix4(object.matrixWorld);
    result = {
      geometry,
      material: Array.isArray(object.material) ? object.material[0]?.clone?.() : object.material?.clone?.(),
    };
  });

  return result;
}

function normalizeOpeningAssetGeometry(sourceGeometry) {
  const geometry = sourceGeometry.clone();
  geometry.computeBoundingBox();
  const box = geometry.boundingBox;
  if (!box || box.isEmpty()) throw new Error("asset GLB avec bounding box vide");

  const size = new THREE.Vector3();
  box.getSize(size);

  // The app places openings from their center. User-authored assets may use a
  // center-bottom origin; normalize to a centered geometry contract here, while
  // keeping the source dimensions as the parametric base size.
  const center = new THREE.Vector3();
  box.getCenter(center);
  geometry.translate(-center.x, -center.y, -center.z);
  geometry.computeVertexNormals();
  geometry.computeBoundingBox();
  geometry.computeBoundingSphere();
  geometry.userData.openingAssetBaseSize = size.clone();
  return geometry;
}

function createGLTFLoader() {
  const loader = new GLTFLoader();
  const dracoLoader = new DRACOLoader();
  dracoLoader.setDecoderPath("/vendor/draco/");
  loader.setDRACOLoader(dracoLoader);
  return loader;
}

function addGeneratedIfcSpacesFromProject(ifcText) {
  if (!state.modelRoot || !ifcText) return 0;

  // If the GLB already contains editable spaces from a previous modeler round-trip,
  // do not duplicate the same IfcSpace volumes from the IFC text.
  const alreadyHasEditableSpaces = state.meshes.some((mesh) =>
    String(mesh.userData?.smeltIfcType || '').toUpperCase() === 'IFCSPACE'
  );
  if (alreadyHasEditableSpaces) return 0;

  const spaces = extractIfcSpaceMeshes(ifcText);
  if (!spaces.length) return 0;

  const group = new THREE.Group();
  group.name = "Generated IFC Spaces";
  group.userData.smeltOverlayGroup = true;

  const material = new THREE.MeshBasicMaterial({
    color: 0x74b9ff,
    transparent: true,
    opacity: 0.30,
    side: THREE.DoubleSide,
    depthWrite: false,
  });

  for (const space of spaces) {
    const mesh = new THREE.Mesh(space.geometry, material.clone());
    mesh.name = space.name || `IfcSpace_${space.localId}`;
    mesh.frustumCulled = false;
    mesh.renderOrder = 2;
    mesh.userData.smeltIfcType = "IFCSPACE";
    mesh.userData.smeltSource = "ifc-generated-overlay";
    mesh.userData.smeltOriginalLocalId = space.localId;
    mesh.userData.smeltPredefinedType = space.predefinedType || ".INTERNAL.";
    mesh.userData.smeltEditableGeneratedSpace = true;
    group.add(mesh);
  }

  state.modelRoot.add(group);
  state.ifcOverlayGroup = group;
  state.ifcOverlayCount = spaces.length;
  return spaces.length;
}

function extractIfcSpaceMeshes(ifcText) {
  const entities = parseIfcEntitiesForModeler(ifcText);
  const out = [];

  for (const entity of entities.values()) {
    if (entity.type !== "IFCSPACE") continue;

    const representationId = parseIfcRefForModeler(entity.rawArgs[6]);
    if (!representationId) continue;

    const geometries = triangulatedGeometriesForRepresentation(entities, representationId);
    if (!geometries.length) continue;

    const geometry = mergeBufferGeometriesForModeler(geometries);
    if (!geometry) continue;

    geometry.computeVertexNormals();
    geometry.computeBoundingBox();
    geometry.computeBoundingSphere();

    out.push({
      localId: entity.id,
      name: parseIfcStringForModeler(entity.rawArgs[2]) || `IfcSpace #${entity.id}`,
      predefinedType: String(entity.rawArgs[9] || ".INTERNAL.").trim(),
      geometry,
    });
  }

  return out;
}

function triangulatedGeometriesForRepresentation(entities, representationId) {
  const geometries = [];
  const visited = new Set();
  const queue = [representationId];

  while (queue.length) {
    const id = queue.shift();
    if (!Number.isFinite(id) || visited.has(id)) continue;
    visited.add(id);

    const entity = entities.get(id);
    if (!entity) continue;

    if (entity.type === "IFCTRIANGULATEDFACESET") {
      const geometry = geometryFromIfcTriangulatedFaceSet(entities, entity);
      if (geometry) geometries.push(geometry);
      continue;
    }

    for (const ref of refsFromIfcArgsForModeler(entity.rawArgs.join(" "))) {
      if (!visited.has(ref)) queue.push(ref);
    }
  }

  return geometries;
}

function geometryFromIfcTriangulatedFaceSet(entities, faceSet) {
  const pointListId = parseIfcRefForModeler(faceSet.rawArgs[0]);
  const pointList = entities.get(pointListId);
  if (!pointList || pointList.type !== "IFCCARTESIANPOINTLIST3D") return null;

  const points = parseIfcPointList3DForModeler(pointList.rawArgs[0]);
  const faces = parseIfcIndexTriplesForModeler(faceSet.rawArgs[3] || faceSet.rawArgs[2]);
  if (!points.length || !faces.length) return null;

  const positions = [];
  for (const [ifcX, ifcY, ifcZ] of points) {
    positions.push(ifcX, ifcZ, -ifcY);
  }

  const indices = [];
  for (const face of faces) {
    indices.push(face[0] - 1, face[1] - 1, face[2] - 1);
  }

  const geometry = new THREE.BufferGeometry();
  geometry.setAttribute("position", new THREE.Float32BufferAttribute(positions, 3));
  geometry.setIndex(indices);
  return geometry;
}

function mergeBufferGeometriesForModeler(geometries) {
  if (!geometries.length) return null;
  if (geometries.length === 1) return geometries[0];

  const positions = [];
  const indices = [];
  let vertexOffset = 0;

  for (const geometry of geometries) {
    const position = geometry.getAttribute("position");
    if (!position) continue;
    for (let i = 0; i < position.count; i++) {
      positions.push(position.getX(i), position.getY(i), position.getZ(i));
    }

    if (geometry.index) {
      for (let i = 0; i < geometry.index.count; i++) indices.push(geometry.index.getX(i) + vertexOffset);
    } else {
      for (let i = 0; i < position.count; i++) indices.push(i + vertexOffset);
    }

    vertexOffset += position.count;
    geometry.dispose?.();
  }

  const merged = new THREE.BufferGeometry();
  merged.setAttribute("position", new THREE.Float32BufferAttribute(positions, 3));
  merged.setIndex(indices);
  return merged;
}

function parseIfcEntitiesForModeler(ifcText) {
  const entities = new Map();
  const re = /#(\d+)\s*=\s*([A-Z0-9_]+)\s*\(([\s\S]*?)\);/gi;
  let match;
  while ((match = re.exec(ifcText))) {
    const id = Number(match[1]);
    const type = match[2].toUpperCase();
    const rawArgs = splitIfcArgsForModeler(match[3]);
    entities.set(id, { id, type, rawArgs });
  }
  return entities;
}

function splitIfcArgsForModeler(text) {
  const args = [];
  let current = "";
  let depth = 0;
  let inString = false;

  for (let i = 0; i < text.length; i++) {
    const char = text[i];
    if (char === "'") {
      current += char;
      if (inString && text[i + 1] === "'") {
        current += text[i + 1];
        i++;
      } else {
        inString = !inString;
      }
      continue;
    }
    if (!inString && char === "(") depth++;
    if (!inString && char === ")") depth--;
    if (!inString && depth === 0 && char === ",") {
      args.push(current.trim());
      current = "";
      continue;
    }
    current += char;
  }
  if (current.trim()) args.push(current.trim());
  return args;
}

function parseIfcRefForModeler(value) {
  const match = String(value || "").match(/#(\d+)/);
  return match ? Number(match[1]) : null;
}

function refsFromIfcArgsForModeler(value) {
  return [...String(value || "").matchAll(/#(\d+)/g)].map((match) => Number(match[1]));
}

function parseIfcStringForModeler(value) {
  const text = String(value || "").trim();
  if (!text || text === "$" || text === "*") return "";
  if (text.startsWith("'") && text.endsWith("'")) return text.slice(1, -1).replace(/''/g, "'");
  return "";
}

function parseIfcPointList3DForModeler(arg) {
  const numbers = [...String(arg || "").matchAll(/[+-]?(?:\d+(?:\.\d*)?|\.\d+)(?:[Ee][+-]?\d+)?/g)]
    .map((match) => Number(match[0]))
    .filter(Number.isFinite);
  const points = [];
  for (let i = 0; i + 2 < numbers.length; i += 3) points.push([numbers[i], numbers[i + 1], numbers[i + 2]]);
  return points;
}

function parseIfcIndexTriplesForModeler(arg) {
  const triples = [];
  const groups = String(arg || "").match(/\([^()]*\)/g) || [];
  for (const group of groups) {
    const nums = [...group.matchAll(/\d+/g)].map((m) => Number(m[0]));
    if (nums.length >= 3) triples.push(nums.slice(0, 3));
  }
  return triples;
}

function indexMeshes(root) {
  state.meshes = [];
  const editableObjects = [];

  root.traverse((object) => {
    if (object.userData?.__modelerOverlay) return;
    if (!object.isMesh && !object.isInstancedMesh) return;
    editableObjects.push(object);
  });

  // Some GLB exporters reuse the same BufferGeometry for several nodes. We clone
  // shared geometries before normalising pivots, otherwise moving one origin would
  // silently move vertices used by another mesh.
  const geometryUseCount = new Map();
  for (const object of editableObjects) {
    if (!object.geometry) continue;
    geometryUseCount.set(object.geometry, (geometryUseCount.get(object.geometry) || 0) + 1);
  }

  for (const object of editableObjects) {
    if (!Number.isFinite(Number(object.userData.__modelerId)) && Number.isFinite(Number(object.userData.modelerId))) {
      object.userData.__modelerId = Number(object.userData.modelerId);
    }

    if (!Number.isFinite(Number(object.userData.__modelerId))) {
      object.userData.__modelerId = state.nextModelerId++;
    } else {
      object.userData.__modelerId = Number(object.userData.__modelerId);
      object.userData.modelerId = object.userData.__modelerId;
      state.nextModelerId = Math.max(state.nextModelerId, object.userData.__modelerId + 1);
    }
    object.name = object.name || object.parent?.name || `Mesh_${object.userData.__modelerId}`;

    if (object.geometry) {
      if (!object.isInstancedMesh && geometryUseCount.get(object.geometry) > 1) {
        object.geometry = object.geometry.clone();
      }

      ensureEditableBufferGeometry(object);
      normalizeEditablePivotToGeometryCenter(object);
      object.geometry.computeBoundingBox();
      object.geometry.computeBoundingSphere();
    }

    // Store the reset transform after pivot normalisation. Visually the mesh is
    // still in the same place, but its local origin is now useful for editing.
    object.userData.__originalTransform = {
      position: object.position.clone(),
      quaternion: object.quaternion.clone(),
      scale: object.scale.clone(),
    };

    state.meshes.push(object);
  }

  if (state.xray.active) applyXrayToMeshes();
}

function ensureEditableBufferGeometry(object) {
  if (!object?.isMesh || object.isInstancedMesh || !object.geometry) return;

  const geometry = object.geometry;
  const position = geometry.getAttribute("position");
  if (!position) return;

  // Transforming vertices needs direct, writable Float32 positions. Some GLB
  // files use interleaved attributes; clone them into a plain BufferAttribute.
  if (position.isInterleavedBufferAttribute || !(position.array instanceof Float32Array)) {
    const positions = new Float32Array(position.count * 3);
    for (let i = 0; i < position.count; i++) {
      positions[i * 3] = position.getX(i);
      positions[i * 3 + 1] = position.getY(i);
      positions[i * 3 + 2] = position.getZ(i);
    }
    geometry.setAttribute("position", new THREE.BufferAttribute(positions, 3));
  }

  const normal = geometry.getAttribute("normal");
  if (normal?.isInterleavedBufferAttribute) {
    geometry.deleteAttribute("normal");
    geometry.computeVertexNormals();
  }
}

function normalizeEditablePivotToGeometryCenter(object) {
  if (!object?.isMesh || object.isInstancedMesh || !object.geometry) return;
  if (object.userData.__pivotNormalized) return;

  const geometry = object.geometry;
  const position = geometry.getAttribute("position");
  if (!position || position.count === 0) return;

  geometry.computeBoundingBox();
  const box = geometry.boundingBox;
  if (!box || box.isEmpty()) return;

  const localCenter = new THREE.Vector3();
  box.getCenter(localCenter);

  if (localCenter.lengthSq() < 1e-18) {
    object.userData.__pivotNormalized = false;
    return;
  }

  // Re-center vertices around the local origin, then compensate the object local
  // transform so the mesh does not visually move. TransformControls attaches to
  // object.position, so this puts the gizmo at the geometry/bbox centre instead
  // of at an arbitrary exporter origin.
  geometry.translate(-localCenter.x, -localCenter.y, -localCenter.z);
  geometry.computeBoundingBox();
  geometry.computeBoundingSphere();

  object.updateMatrix();
  const compensatedLocalMatrix = object.matrix.clone().multiply(
    new THREE.Matrix4().makeTranslation(localCenter.x, localCenter.y, localCenter.z)
  );
  compensatedLocalMatrix.decompose(object.position, object.quaternion, object.scale);
  object.updateMatrix();
  object.updateMatrixWorld(true);

  object.userData.__pivotNormalized = true;
  object.userData.__pivotOffset = localCenter.toArray();
}

function clearScene(options = {}) {
  selectMesh(null);
  state.edit.active = false;
  cancelAuthoringDraw();
  cancelReferenceCalibration();
  cancelBoxSelect();
  clearEditComponentSelection();
  removeEditOverlay();

  if (state.modelRoot) {
    state.scene.remove(state.modelRoot);
    disposeObject(state.modelRoot);
  }

  removeAllReferencePlans();

  for (const url of state.objectUrls) URL.revokeObjectURL(url);
  state.objectUrls.clear();

  state.modelRoot = null;
  state.nextModelerId = 1;
  state.currentFile = null;
  state.currentFileName = "";
  state.ifcOverlayGroup = null;
  state.ifcOverlayCount = 0;
  state.meshes = [];
  state.history.undoStack.length = 0;
  state.history.redoStack.length = 0;
  state.history.objectDragStart = null;
  state.authoring.wallCount = 0;
  state.authoring.partitionCount = 0;
  state.authoring.slabCount = 0;
  state.authoring.doorCount = 0;
  state.authoring.windowCount = 0;
  state.authoring.roofCount = 0;
  state.authoring.stairCount = 0;
  state.authoring.tool = "select";
  resetAuthoringStoreys();
  renderTree();
  renderProperties();
  updateUiEnabled();

  if (!options.silent) setStatus("Scène vidée.");
}

function disposeObject(root) {
  root.traverse((object) => {
    if (object.geometry) object.geometry.dispose?.();
    disposeMaterial(object.material);
  });
}

function disposeMaterial(materialOrMaterials) {
  if (!materialOrMaterials) return;
  const materials = Array.isArray(materialOrMaterials) ? materialOrMaterials : [materialOrMaterials];
  for (const material of materials) {
    if (!material) continue;
    for (const key of ["map", "alphaMap", "emissiveMap", "normalMap", "roughnessMap", "metalnessMap", "envMap"]) {
      material?.[key]?.dispose?.();
    }
    material?.dispose?.();
  }
}

function renderTree() {
  const query = normalize(treeSearch.value);
  const meshes = state.meshes.filter((mesh) => normalize(mesh.name).includes(query));

  if (!state.modelRoot) {
    tree.innerHTML = `<div class="tree-empty">Charge un GLB pour voir les meshes éditables.</div>`;
    return;
  }

  if (meshes.length === 0) {
    tree.innerHTML = `<div class="tree-empty">Aucun mesh ne correspond au filtre.</div>`;
    return;
  }

  tree.innerHTML = meshes.map((mesh) => {
    const stats = geometryStats(mesh);
    const selected = mesh === state.selected ? " selected" : "";
    return `
      <div class="tree-item${selected}" data-id="${mesh.userData.__modelerId}">
        <div class="tree-main">
          <div class="tree-name">${escapeHtml(mesh.name || `Mesh ${mesh.userData.__modelerId}`)}</div>
          <div class="tree-meta">${stats.vertices} vertices · ${stats.triangles} triangles${meshStoreyLabel(mesh) ? ` · ${escapeHtml(meshStoreyLabel(mesh))}` : ""}</div>
        </div>
        <div class="tree-badge">#${mesh.userData.__modelerId}</div>
      </div>
    `;
  }).join("");

  for (const item of tree.querySelectorAll(".tree-item")) {
    item.addEventListener("click", () => {
      const id = Number(item.dataset.id);
      selectMesh(state.meshes.find((mesh) => mesh.userData.__modelerId === id) || null);
    });
  }
}

function meshStoreyLabel(mesh) {
  return mesh?.userData?.storeyName || "";
}

function normalize(value) {
  return String(value || "")
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .trim();
}

function onViewportWheel() {
  clearBrowserSelection();
  // OrbitControls handles ortho zoom directly. Clearing pointerDown prevents
  // a wheel/trackpad gesture from being interpreted as a left-drag orbit,
  // so zooming does not exit orthographic numpad views.
  if (state.camera?.isOrthographicCamera) state.pointerDown = null;
}

function onPointerDown(event) {
  if (event.button !== 0) return;
  beginViewportPointerInteraction();
  event.preventDefault();

  if (state.edit.active && state.selectBox.armed && canEditSubGeometry(state.selected)) {
    startBoxSelect(event);
    return;
  }

  state.pointerDown = {
    x: event.clientX,
    y: event.clientY,
    time: performance.now(),
    authoringTool: isDrawingAuthoringTool() ? state.authoring.tool : null,
    orthoCamera: state.camera?.isOrthographicCamera === true,
    panModifier: Boolean(event.shiftKey || event.ctrlKey || event.metaKey || event.altKey),
  };
}

function onPointerMove(event) {
  if (state.pointerDown || state.selectBox.dragging || isDrawingAuthoringTool()) clearBrowserSelection();
  if (state.authoring.calibration.active && state.authoring.calibration.start) {
    updateReferenceCalibrationPreviewFromEvent(event);
    return;
  }

  maybeSwitchFromOrthoToPerspectiveOnDrag(event);

  if (isDrawingAuthoringTool()) {
    updateAuthoringPreviewFromEvent(event);
    return;
  }

  if (state.selectBox.dragging) {
    updateBoxSelect(event);
  }
}

function onPointerLeave(event) {
  if (state.pointerDown || state.selectBox.dragging || isDrawingAuthoringTool()) clearBrowserSelection();
  if (state.authoring.calibration.active && state.authoring.calibration.start) {
    updateReferenceCalibrationPreviewFromEvent(event);
    return;
  }

  maybeSwitchFromOrthoToPerspectiveOnDrag(event);

  if (isDrawingAuthoringTool()) {
    updateAuthoringPreviewFromEvent(event);
    return;
  }

  if (state.selectBox.dragging) {
    updateBoxSelect(event);
  }
}

function onPointerUp(event) {
  endViewportPointerInteraction();
  event.preventDefault();

  if (state.selectBox.dragging) {
    finishBoxSelect(event);
    return;
  }

  const pointerDown = state.pointerDown;
  if (!pointerDown) return;
  state.pointerDown = null;
  if (state.isTransformDragging) return;

  const dx = event.clientX - pointerDown.x;
  const dy = event.clientY - pointerDown.y;
  const moved = Math.hypot(dx, dy);
  const elapsed = performance.now() - pointerDown.time;

  if (moved > 4 || elapsed > 550) return;

  if (state.authoring.calibration.active) {
    handleReferenceCalibrationClick(event);
    return;
  }

  if (pointerDown.authoringTool && pointerDown.authoringTool === state.authoring.tool && isDrawingAuthoringTool()) {
    handleAuthoringClick(event);
    return;
  }

  selectFromPointer(event);
}

function selectFromPointer(event) {
  if (state.edit.active) {
    selectEditComponentFromPointer(event);
    return;
  }

  if (!state.meshes.length) return;

  const rect = state.renderer.domElement.getBoundingClientRect();
  state.pointer.x = ((event.clientX - rect.left) / rect.width) * 2 - 1;
  state.pointer.y = -((event.clientY - rect.top) / rect.height) * 2 + 1;

  state.raycaster.setFromCamera(state.pointer, state.camera);
  const hits = state.raycaster.intersectObjects(state.meshes, false);
  const hit = hits.find((entry) => entry.object?.isMesh || entry.object?.isInstancedMesh);
  selectMesh(hit?.object || null);
}

function selectMesh(mesh) {
  if (state.edit.active && mesh !== state.selected) {
    setEditMode(false);
  }

  state.selected = mesh || null;

  if (state.selected) {
    if (state.edit.active) {
      updateEditPivotToSelection();
    } else {
      state.transform.enabled = true;
      state.transform.attach(state.selected);
      state.transform.setSize?.(1.15);
    }
  } else {
    clearEditComponentSelection();
    state.transform.detach();
  }

  if (state.transformHelper) {
    state.transformHelper.visible = Boolean(state.selected) && (!state.edit.active || hasEditComponentSelection());
  }

  updateBoxHelper();
  if (state.authoring.tool === "roof") updateRoofPreviewFromSelection();
  renderTree();
  renderProperties();
  updateUiEnabled();
}

function setEditMode(active) {
  const nextActive = Boolean(active);

  if (nextActive) {
    if (!state.selected) {
      setStatus("Sélectionne d’abord un mesh, puis active le mode édition.", "warning");
      updateUiEnabled();
      return;
    }

    if (!canEditSubGeometry(state.selected)) {
      setStatus("Ce mesh ne peut pas être édité au niveau vertex/edge/face. Les InstancedMesh restent éditables en mode objet.", "warning");
      updateUiEnabled();
      return;
    }
  }

  if (state.edit.active === nextActive) {
    updateUiEnabled();
    return;
  }

  state.edit.active = nextActive;
  clearEditComponentSelection({ keepOverlayShell: nextActive });

  if (state.edit.active) {
    state.transform.detach();
    state.transform.setSpace("local");
    state.transform.setMode("translate");
    rebuildEditOverlay();
    setStatus(`Mode édition · ${componentModeLabel(state.edit.componentMode)} · clic = sélectionner · Shift/Ctrl+clic = ajouter/retirer · B = box select · A = tout sélectionner.`, "ok");
  } else {
    cancelBoxSelect();
    removeEditOverlay();
    state.transform.detach();
    if (state.selected) {
      state.transform.attach(state.selected);
      state.transform.setSize?.(1.15);
    }
  }

  updateBoxHelper();
  renderProperties();
  updateUiEnabled();
}

function canEditSubGeometry(mesh) {
  return Boolean(mesh?.isMesh && !mesh.isInstancedMesh && mesh.geometry?.getAttribute("position"));
}

function setComponentMode(mode) {
  if (!["vertex", "edge", "face"].includes(mode)) return;
  state.edit.componentMode = mode;
  clearEditComponentSelection({ keepOverlayShell: true });
  rebuildEditOverlay();
  setStatus(`Mode édition · ${componentModeLabel(mode)} · clic/tweak ou B pour Box Select.`, "ok");
  renderProperties();
  updateUiEnabled();
}

function componentModeLabel(mode = state.edit.componentMode) {
  if (mode === "vertex") return "Vertex";
  if (mode === "edge") return "Edge";
  if (mode === "face") return "Face";
  return "Edit";
}

function clearEditComponentSelection(options = {}) {
  state.edit.vertexIds.clear();
  state.edit.edgeKeys.clear();
  state.edit.faceIds.clear();
  state.edit.dragStart = null;

  if (state.edit.active && options.keepOverlayShell) {
    updateEditPivotToSelection();
    rebuildEditOverlay();
  } else if (!options.keepOverlayShell) {
    if (state.edit.active) rebuildEditOverlay();
    state.transform.detach();
  }

  if (state.transformHelper) state.transformHelper.visible = false;
  renderProperties();
  updateUiEnabled();
}

function hasEditComponentSelection() {
  return state.edit.vertexIds.size > 0 || state.edit.edgeKeys.size > 0 || state.edit.faceIds.size > 0;
}

function selectEditComponentFromPointer(event) {
  const mesh = state.selected;
  if (!canEditSubGeometry(mesh)) return;

  const additiveSelect = isAdditiveSelectEvent(event);

  if (!additiveSelect) {
    state.edit.vertexIds.clear();
    state.edit.edgeKeys.clear();
    state.edit.faceIds.clear();
  }

  let picked = false;

  if (state.edit.componentMode === "vertex") {
    const vertexId = pickVertexNearPointer(mesh, event);
    if (vertexId !== null) {
      toggleSetValue(state.edit.vertexIds, vertexId, additiveSelect);
      picked = true;
    }
  } else if (state.edit.componentMode === "edge") {
    const edge = pickEdgeNearPointer(mesh, event);
    if (edge !== null) {
      toggleSetValue(state.edit.edgeKeys, edge, additiveSelect);
      picked = true;
    }
  } else if (state.edit.componentMode === "face") {
    const faceIndex = pickFaceFromPointer(mesh, event);
    if (faceIndex !== null) {
      toggleSetValue(state.edit.faceIds, faceIndex, additiveSelect);
      picked = true;
    }
  }

  if (!picked && additiveSelect) return;

  updateEditPivotToSelection();
  rebuildEditOverlay();
  renderProperties();
  updateUiEnabled();
}


function pickFaceFromPointer(mesh, event) {
  const hit = raycastSelectedMesh(mesh, event);
  return hit?.face && Number.isFinite(hit.faceIndex) ? hit.faceIndex : null;
}

function pickVertexNearPointer(mesh, event) {
  const position = mesh.geometry.getAttribute("position");
  if (!position) return null;

  const pointer = pointerClientPosition(event);
  const threshold = 16;
  const thresholdSq = threshold * threshold;
  const tmp = new THREE.Vector3();
  let bestId = null;
  let bestDistSq = Infinity;

  mesh.updateMatrixWorld(true);
  for (let id = 0; id < position.count; id++) {
    tmp.fromBufferAttribute(position, id);
    mesh.localToWorld(tmp);
    const screen = worldToClient(tmp);
    if (!screen.visible) continue;

    const dx = screen.x - pointer.x;
    const dy = screen.y - pointer.y;
    const distSq = dx * dx + dy * dy;
    if (distSq <= thresholdSq && distSq < bestDistSq) {
      bestDistSq = distSq;
      bestId = id;
    }
  }

  if (bestId !== null) return bestId;

  const hit = raycastSelectedMesh(mesh, event);
  const tri = hit?.face && Number.isFinite(hit.faceIndex) ? triangleVertexIds(mesh.geometry, hit.faceIndex) : null;
  return tri ? closestTriangleVertexToPoint(mesh, tri, hit.point) : null;
}

function pickEdgeNearPointer(mesh, event) {
  const geometry = mesh.geometry;
  const position = geometry.getAttribute("position");
  if (!position) return null;

  const pointer = pointerClientPosition(event);
  const threshold = 12;
  const thresholdSq = threshold * threshold;
  const faceCount = triangleCount(geometry);
  const visited = new Set();
  let bestKey = null;
  let bestDistSq = Infinity;

  for (let faceIndex = 0; faceIndex < faceCount; faceIndex++) {
    const tri = triangleVertexIds(geometry, faceIndex);
    if (!tri) continue;
    const edges = [[tri[0], tri[1]], [tri[1], tri[2]], [tri[2], tri[0]]];
    for (const [a, b] of edges) {
      const key = edgeKey(a, b);
      if (visited.has(key)) continue;
      visited.add(key);
      const distSq = distanceClientPointToVertexSegmentSq(mesh, pointer, a, b);
      if (distSq <= thresholdSq && distSq < bestDistSq) {
        bestDistSq = distSq;
        bestKey = key;
      }
    }
  }

  if (bestKey !== null) return bestKey;

  const hit = raycastSelectedMesh(mesh, event);
  const tri = hit?.face && Number.isFinite(hit.faceIndex) ? triangleVertexIds(mesh.geometry, hit.faceIndex) : null;
  return tri ? closestTriangleEdgeToPoint(mesh, tri, hit.point) : null;
}

function raycastSelectedMesh(mesh, event) {
  const rect = state.renderer.domElement.getBoundingClientRect();
  state.pointer.x = ((event.clientX - rect.left) / rect.width) * 2 - 1;
  state.pointer.y = -((event.clientY - rect.top) / rect.height) * 2 + 1;
  state.raycaster.setFromCamera(state.pointer, state.camera);
  return state.raycaster.intersectObject(mesh, false)[0] || null;
}

function pointerClientPosition(event) {
  return { x: event.clientX, y: event.clientY };
}

function worldToClient(world) {
  const rect = state.renderer.domElement.getBoundingClientRect();
  const projected = world.clone().project(state.camera);
  return {
    x: rect.left + (projected.x * 0.5 + 0.5) * rect.width,
    y: rect.top + (-projected.y * 0.5 + 0.5) * rect.height,
    z: projected.z,
    visible: projected.z >= -1 && projected.z <= 1,
  };
}

function distanceClientPointToVertexSegmentSq(mesh, point, a, b) {
  const position = mesh.geometry.getAttribute("position");
  if (!Number.isFinite(a) || !Number.isFinite(b) || a < 0 || b < 0 || a >= position.count || b >= position.count) return Infinity;

  const pa = new THREE.Vector3().fromBufferAttribute(position, a);
  const pb = new THREE.Vector3().fromBufferAttribute(position, b);
  mesh.localToWorld(pa);
  mesh.localToWorld(pb);
  const sa = worldToClient(pa);
  const sb = worldToClient(pb);
  if (!sa.visible && !sb.visible) return Infinity;

  const abx = sb.x - sa.x;
  const aby = sb.y - sa.y;
  const lenSq = abx * abx + aby * aby;
  const t = lenSq > 1e-9
    ? THREE.MathUtils.clamp(((point.x - sa.x) * abx + (point.y - sa.y) * aby) / lenSq, 0, 1)
    : 0;
  const x = sa.x + abx * t;
  const y = sa.y + aby * t;
  const dx = point.x - x;
  const dy = point.y - y;
  return dx * dx + dy * dy;
}

function armBoxSelect() {
  if (!state.edit.active || !canEditSubGeometry(state.selected)) {
    setStatus("Active le mode édition sur un mesh avant Box Select.", "warning");
    return;
  }

  state.selectBox.armed = true;
  state.edit.selectionTool = "box";
  updateToolbarState();
  setStatus("Box Select armé · glisse un rectangle dans la vue. Shift/Ctrl = ajouter, Alt = retirer, Échap = annuler.", "ok");
}

function cancelBoxSelect() {
  state.selectBox.armed = false;
  state.selectBox.dragging = false;
  state.selectBox.start = null;
  state.selectBox.current = null;
  state.edit.selectionTool = "tweak";
  state.controls.enabled = !state.isTransformDragging;
  removeBoxSelectElement();
  updateToolbarState();
}

function startBoxSelect(event) {
  event.preventDefault();
  event.stopPropagation();
  state.pointerDown = null;
  state.selectBox.dragging = true;
  state.selectBox.start = { x: event.clientX, y: event.clientY };
  state.selectBox.current = { x: event.clientX, y: event.clientY };
  state.controls.enabled = false;
  ensureBoxSelectElement();
  drawBoxSelectElement();
}

function updateBoxSelect(event) {
  state.selectBox.current = { x: event.clientX, y: event.clientY };
  drawBoxSelectElement();
}

function finishBoxSelect(event) {
  state.selectBox.current = { x: event.clientX, y: event.clientY };
  const rect = currentBoxSelectRect();
  const distance = Math.hypot(rect.width, rect.height);

  if (distance > 5) {
    selectEditComponentsInBox(rect, event);
  }

  cancelBoxSelect();
}

function ensureBoxSelectElement() {
  if (state.selectBox.element) return;
  const element = document.createElement("div");
  element.className = "select-box-rect";
  container.appendChild(element);
  state.selectBox.element = element;
}

function removeBoxSelectElement() {
  if (state.selectBox.element?.parentElement) state.selectBox.element.parentElement.removeChild(state.selectBox.element);
  state.selectBox.element = null;
}

function drawBoxSelectElement() {
  const element = state.selectBox.element;
  if (!element || !state.selectBox.start || !state.selectBox.current) return;
  const rect = currentBoxSelectRect();
  const containerRect = container.getBoundingClientRect();
  element.style.left = `${rect.left - containerRect.left}px`;
  element.style.top = `${rect.top - containerRect.top}px`;
  element.style.width = `${rect.width}px`;
  element.style.height = `${rect.height}px`;
}

function currentBoxSelectRect() {
  const start = state.selectBox.start || { x: 0, y: 0 };
  const current = state.selectBox.current || start;
  const left = Math.min(start.x, current.x);
  const top = Math.min(start.y, current.y);
  const right = Math.max(start.x, current.x);
  const bottom = Math.max(start.y, current.y);
  return { left, top, right, bottom, width: right - left, height: bottom - top };
}

function selectEditComponentsInBox(rect, event) {
  const mesh = state.selected;
  if (!canEditSubGeometry(mesh)) return;

  const additive = isAdditiveSelectEvent(event);
  const subtract = Boolean(event?.altKey);

  if (!additive && !subtract) {
    state.edit.vertexIds.clear();
    state.edit.edgeKeys.clear();
    state.edit.faceIds.clear();
  }

  const found = componentsInsideClientRect(mesh, rect, state.edit.componentMode);
  const targetSet = state.edit.componentMode === "vertex"
    ? state.edit.vertexIds
    : state.edit.componentMode === "edge"
      ? state.edit.edgeKeys
      : state.edit.faceIds;

  for (const value of found) {
    if (subtract) targetSet.delete(value);
    else targetSet.add(value);
  }

  updateEditPivotToSelection();
  rebuildEditOverlay();
  renderProperties();
  updateUiEnabled();
}

function componentsInsideClientRect(mesh, rect, mode) {
  const geometry = mesh.geometry;
  const position = geometry.getAttribute("position");
  const out = [];
  if (!position) return out;

  mesh.updateMatrixWorld(true);

  if (mode === "vertex") {
    const tmp = new THREE.Vector3();
    for (let id = 0; id < position.count; id++) {
      tmp.fromBufferAttribute(position, id);
      mesh.localToWorld(tmp);
      const screen = worldToClient(tmp);
      if (screen.visible && clientPointInRect(screen, rect)) out.push(id);
    }
    return out;
  }

  const faceCount = triangleCount(geometry);
  const uniqueEdges = new Set();
  const a = new THREE.Vector3();
  const b = new THREE.Vector3();
  const c = new THREE.Vector3();

  for (let faceIndex = 0; faceIndex < faceCount; faceIndex++) {
    const tri = triangleVertexIds(geometry, faceIndex);
    if (!tri) continue;

    if (mode === "edge") {
      for (const [i, j] of [[tri[0], tri[1]], [tri[1], tri[2]], [tri[2], tri[0]]]) {
        const key = edgeKey(i, j);
        if (uniqueEdges.has(key)) continue;
        uniqueEdges.add(key);
        if (edgeIntersectsClientRect(mesh, i, j, rect)) out.push(key);
      }
      continue;
    }

    a.fromBufferAttribute(position, tri[0]);
    b.fromBufferAttribute(position, tri[1]);
    c.fromBufferAttribute(position, tri[2]);
    mesh.localToWorld(a);
    mesh.localToWorld(b);
    mesh.localToWorld(c);
    const centroid = a.add(b).add(c).multiplyScalar(1 / 3);
    const screen = worldToClient(centroid);
    if (screen.visible && clientPointInRect(screen, rect)) out.push(faceIndex);
  }

  return out;
}

function edgeIntersectsClientRect(mesh, aId, bId, rect) {
  const position = mesh.geometry.getAttribute("position");
  const a = new THREE.Vector3().fromBufferAttribute(position, aId);
  const b = new THREE.Vector3().fromBufferAttribute(position, bId);
  mesh.localToWorld(a);
  mesh.localToWorld(b);
  const sa = worldToClient(a);
  const sb = worldToClient(b);
  if (!sa.visible && !sb.visible) return false;
  if (clientPointInRect(sa, rect) || clientPointInRect(sb, rect)) return true;

  // Midpoint catch keeps thin/long edges pleasant to select without a full 2D line clipping implementation.
  return clientPointInRect({ x: (sa.x + sb.x) / 2, y: (sa.y + sb.y) / 2 }, rect);
}

function clientPointInRect(point, rect) {
  return point.x >= rect.left && point.x <= rect.right && point.y >= rect.top && point.y <= rect.bottom;
}

function isAdditiveSelectEvent(event) {
  return Boolean(event?.shiftKey || event?.ctrlKey || event?.metaKey);
}

function toggleSetValue(set, value, shouldToggle) {
  if (value === null || value === undefined) return;
  if (shouldToggle && set.has(value)) set.delete(value);
  else set.add(value);
}

function selectAllEditComponents() {
  const mesh = state.selected;
  if (!state.edit.active || !canEditSubGeometry(mesh)) return;

  const geometry = mesh.geometry;
  const position = geometry.getAttribute("position");
  const faceCount = triangleCount(geometry);

  state.edit.vertexIds.clear();
  state.edit.edgeKeys.clear();
  state.edit.faceIds.clear();

  if (state.edit.componentMode === "vertex") {
    for (let i = 0; i < position.count; i++) state.edit.vertexIds.add(i);
  } else if (state.edit.componentMode === "edge") {
    for (let faceIndex = 0; faceIndex < faceCount; faceIndex++) {
      const tri = triangleVertexIds(geometry, faceIndex);
      if (!tri) continue;
      state.edit.edgeKeys.add(edgeKey(tri[0], tri[1]));
      state.edit.edgeKeys.add(edgeKey(tri[1], tri[2]));
      state.edit.edgeKeys.add(edgeKey(tri[2], tri[0]));
    }
  } else if (state.edit.componentMode === "face") {
    for (let faceIndex = 0; faceIndex < faceCount; faceIndex++) state.edit.faceIds.add(faceIndex);
  }

  updateEditPivotToSelection();
  rebuildEditOverlay();
  renderProperties();
  markDirty();
  updateUiEnabled();
}

function selectedEditVertexIds() {
  const mesh = state.selected;
  const ids = new Set(state.edit.vertexIds);

  for (const key of state.edit.edgeKeys) {
    const [a, b] = parseEdgeKey(key);
    if (Number.isFinite(a)) ids.add(a);
    if (Number.isFinite(b)) ids.add(b);
  }

  for (const faceIndex of state.edit.faceIds) {
    const tri = triangleVertexIds(mesh?.geometry, faceIndex);
    if (!tri) continue;
    ids.add(tri[0]);
    ids.add(tri[1]);
    ids.add(tri[2]);
  }

  return ids;
}

function updateEditPivotToSelection() {
  if (!state.edit.active || !state.selected || !state.edit.pivot) return;

  const ids = selectedEditVertexIds();
  if (ids.size === 0) {
    state.transform.detach();
    if (state.transformHelper) state.transformHelper.visible = false;
    return;
  }

  const position = state.selected.geometry.getAttribute("position");
  const center = new THREE.Vector3();
  const tmp = new THREE.Vector3();
  let count = 0;

  state.selected.updateMatrixWorld(true);
  for (const id of ids) {
    if (id < 0 || id >= position.count) continue;
    tmp.fromBufferAttribute(position, id);
    state.selected.localToWorld(tmp);
    center.add(tmp);
    count++;
  }

  if (count === 0) return;
  center.multiplyScalar(1 / count);

  state.edit.pivot.position.copy(center);
  state.edit.pivot.quaternion.identity();
  state.edit.pivot.scale.set(1, 1, 1);
  state.edit.pivot.updateMatrixWorld(true);

  state.transform.enabled = true;
  state.transform.attach(state.edit.pivot);
  state.transform.setSize?.(0.82);
  if (state.transformHelper) state.transformHelper.visible = true;
}

function beginEditTransformDrag() {
  const mesh = state.selected;
  if (!state.edit.active || !canEditSubGeometry(mesh)) return;

  const ids = selectedEditVertexIds();
  if (ids.size === 0) return;

  mesh.updateMatrixWorld(true);
  state.edit.pivot.updateMatrixWorld(true);
  const position = mesh.geometry.getAttribute("position");
  const vertices = new Map();
  const tmp = new THREE.Vector3();

  for (const id of ids) {
    if (id < 0 || id >= position.count) continue;
    tmp.fromBufferAttribute(position, id);
    vertices.set(id, tmp.clone());
  }

  state.edit.dragStart = {
    vertices,
    meshMatrixWorld: mesh.matrixWorld.clone(),
    meshMatrixWorldInverse: mesh.matrixWorld.clone().invert(),
    pivotMatrixWorld: state.edit.pivot.matrixWorld.clone(),
  };
}

function applyEditTransformFromPivot() {
  const mesh = state.selected;
  const dragStart = state.edit.dragStart;
  if (!state.edit.active || !dragStart || !canEditSubGeometry(mesh)) return;

  mesh.updateMatrixWorld(true);
  state.edit.pivot.updateMatrixWorld(true);

  const deltaWorld = state.edit.pivot.matrixWorld.clone().multiply(dragStart.pivotMatrixWorld.clone().invert());
  const position = mesh.geometry.getAttribute("position");
  const local = new THREE.Vector3();
  const world = new THREE.Vector3();

  for (const [id, startLocal] of dragStart.vertices.entries()) {
    world.copy(startLocal).applyMatrix4(dragStart.meshMatrixWorld).applyMatrix4(deltaWorld);
    local.copy(world).applyMatrix4(dragStart.meshMatrixWorldInverse);
    position.setXYZ(id, local.x, local.y, local.z);
  }

  position.needsUpdate = true;
  mesh.geometry.computeVertexNormals();
  mesh.geometry.computeBoundingBox();
  mesh.geometry.computeBoundingSphere();
  updateBoxHelper();
  rebuildEditOverlay();
  markDirty();
}

function finishEditTransformDrag() {
  const dragStart = state.edit.dragStart;
  if (!dragStart) return;

  const mesh = state.selected;
  const after = mesh ? vertexEntriesFromGeometry(mesh, dragStart.vertices.keys()) : [];
  const before = vertexEntriesFromStartMap(dragStart.vertices);

  state.edit.dragStart = null;

  if (mesh && vertexEntriesChanged(before, after)) {
    pushHistory({
      type: "geometryPatch",
      label: `${componentModeLabel()} move`,
      meshId: mesh.userData.__modelerId,
      before,
      after,
    });
  }

  updateEditPivotToSelection();
  rebuildEditOverlay();
  renderProperties();
  markDirty();
}

function rebuildEditOverlay() {
  removeEditOverlay();

  const mesh = state.selected;
  if (!state.edit.active || !canEditSubGeometry(mesh)) return;

  const group = new THREE.Group();
  group.name = "Edit mode overlay";
  group.userData.__modelerOverlay = true;
  group.renderOrder = 30;

  const geometry = mesh.geometry;
  const position = geometry.getAttribute("position");

  if (position.count <= MAX_VISIBLE_EDIT_VERTICES) {
    const pointsGeometry = new THREE.BufferGeometry();
    pointsGeometry.setAttribute("position", position.clone());
    const points = new THREE.Points(pointsGeometry, editVertexMaterial.clone());
    points.name = "Vertices overlay";
    points.userData.__modelerOverlay = true;
    points.renderOrder = 31;
    group.add(points);
  }

  const wireGeometry = new THREE.WireframeGeometry(geometry);
  const wire = new THREE.LineSegments(wireGeometry, editWireMaterial.clone());
  wire.name = "Edges overlay";
  wire.userData.__modelerOverlay = true;
  wire.renderOrder = 30;
  group.add(wire);

  addSelectedComponentsOverlay(mesh, group);

  mesh.add(group);
  state.edit.overlayGroup = group;
}

function removeEditOverlay() {
  const overlay = state.edit.overlayGroup;
  if (overlay?.parent) overlay.parent.remove(overlay);
  if (overlay) disposeObject(overlay);
  state.edit.overlayGroup = null;
}

function addSelectedComponentsOverlay(mesh, group) {
  const geometry = mesh.geometry;
  const position = geometry.getAttribute("position");
  const selectedIds = selectedEditVertexIds();

  if (selectedIds.size > 0) {
    const selectedPositions = [];
    for (const id of selectedIds) {
      if (id < 0 || id >= position.count) continue;
      selectedPositions.push(position.getX(id), position.getY(id), position.getZ(id));
    }
    if (selectedPositions.length) {
      const g = new THREE.BufferGeometry();
      g.setAttribute("position", new THREE.Float32BufferAttribute(selectedPositions, 3));
      const points = new THREE.Points(g, editSelectedPointMaterial.clone());
      points.name = "Selected vertices";
      points.userData.__modelerOverlay = true;
      points.renderOrder = 34;
      group.add(points);
    }
  }

  const selectedLines = [];

  for (const key of state.edit.edgeKeys) {
    const [a, b] = parseEdgeKey(key);
    pushLinePositions(selectedLines, position, a, b);
  }

  for (const faceIndex of state.edit.faceIds) {
    const tri = triangleVertexIds(geometry, faceIndex);
    if (!tri) continue;
    pushLinePositions(selectedLines, position, tri[0], tri[1]);
    pushLinePositions(selectedLines, position, tri[1], tri[2]);
    pushLinePositions(selectedLines, position, tri[2], tri[0]);
  }

  if (selectedLines.length) {
    const g = new THREE.BufferGeometry();
    g.setAttribute("position", new THREE.Float32BufferAttribute(selectedLines, 3));
    const lines = new THREE.LineSegments(g, editSelectedLineMaterial.clone());
    lines.name = "Selected edges";
    lines.userData.__modelerOverlay = true;
    lines.renderOrder = 33;
    group.add(lines);
  }

  if (state.edit.faceIds.size > 0) {
    const facePositions = [];
    for (const faceIndex of state.edit.faceIds) {
      const tri = triangleVertexIds(geometry, faceIndex);
      if (!tri) continue;
      for (const id of tri) {
        facePositions.push(position.getX(id), position.getY(id), position.getZ(id));
      }
    }
    if (facePositions.length) {
      const g = new THREE.BufferGeometry();
      g.setAttribute("position", new THREE.Float32BufferAttribute(facePositions, 3));
      g.computeVertexNormals();
      const faces = new THREE.Mesh(g, editSelectedFaceMaterial.clone());
      faces.name = "Selected faces";
      faces.userData.__modelerOverlay = true;
      faces.renderOrder = 32;
      group.add(faces);
    }
  }
}

function pushLinePositions(out, position, a, b) {
  if (!Number.isFinite(a) || !Number.isFinite(b)) return;
  if (a < 0 || b < 0 || a >= position.count || b >= position.count) return;
  out.push(
    position.getX(a), position.getY(a), position.getZ(a),
    position.getX(b), position.getY(b), position.getZ(b),
  );
}

function triangleCount(geometry) {
  const position = geometry?.getAttribute("position");
  if (!position) return 0;
  return geometry.index ? Math.floor(geometry.index.count / 3) : Math.floor(position.count / 3);
}

function triangleVertexIds(geometry, faceIndex) {
  if (!geometry || !Number.isFinite(faceIndex) || faceIndex < 0) return null;
  const start = faceIndex * 3;
  const position = geometry.getAttribute("position");
  if (!position) return null;

  if (geometry.index) {
    if (start + 2 >= geometry.index.count) return null;
    return [geometry.index.getX(start), geometry.index.getX(start + 1), geometry.index.getX(start + 2)];
  }

  if (start + 2 >= position.count) return null;
  return [start, start + 1, start + 2];
}

function closestTriangleVertexToPoint(mesh, tri, worldPoint) {
  const position = mesh.geometry.getAttribute("position");
  const tmp = new THREE.Vector3();
  let bestId = tri[0];
  let bestDist = Infinity;

  for (const id of tri) {
    tmp.fromBufferAttribute(position, id);
    mesh.localToWorld(tmp);
    const dist = tmp.distanceToSquared(worldPoint);
    if (dist < bestDist) {
      bestDist = dist;
      bestId = id;
    }
  }

  return bestId;
}

function closestTriangleEdgeToPoint(mesh, tri, worldPoint) {
  const edges = [
    [tri[0], tri[1]],
    [tri[1], tri[2]],
    [tri[2], tri[0]],
  ];

  let best = edges[0];
  let bestDist = Infinity;

  for (const candidate of edges) {
    const dist = distancePointToWorldSegmentSquared(mesh, worldPoint, candidate[0], candidate[1]);
    if (dist < bestDist) {
      bestDist = dist;
      best = candidate;
    }
  }

  return edgeKey(best[0], best[1]);
}

function distancePointToWorldSegmentSquared(mesh, point, a, b) {
  const position = mesh.geometry.getAttribute("position");
  const pa = new THREE.Vector3().fromBufferAttribute(position, a);
  const pb = new THREE.Vector3().fromBufferAttribute(position, b);
  mesh.localToWorld(pa);
  mesh.localToWorld(pb);

  const ab = pb.sub(pa);
  const t = THREE.MathUtils.clamp(point.clone().sub(pa).dot(ab) / Math.max(ab.lengthSq(), 1e-18), 0, 1);
  return pa.add(ab.multiplyScalar(t)).distanceToSquared(point);
}

function edgeKey(a, b) {
  return a < b ? `${a}:${b}` : `${b}:${a}`;
}

function parseEdgeKey(key) {
  return String(key || "").split(":").map((value) => Number(value));
}

function updateBoxHelper() {
  if (state.boxHelper) {
    state.scene.remove(state.boxHelper);
    state.boxHelper.geometry?.dispose?.();
    state.boxHelper.material?.dispose?.();
    state.boxHelper = null;
